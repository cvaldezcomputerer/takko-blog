{
  "main": "dist/_worker.js/index.js",
  "name": "takko-blog",
  "compatibility_date": "2026-01-16",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "takko-blog-likes",
      "database_id": "2dbfa341-2ba6-4fda-a9bc-9165a74b275a",
      "migrations_dir": "migrations"
    }
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}
