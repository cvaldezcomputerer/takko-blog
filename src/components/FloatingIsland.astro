---
import { Image } from 'astro:assets';
import LanguageSelector from './LanguageSelector.astro';
import logoImage from '../assets/images/logo.png';

// Determine where the "Back" button should go
const backLink = Astro.url.pathname.startsWith('/blog/') && Astro.url.pathname !== '/blog' && Astro.url.pathname !== '/blog/' ? '/blog' : '/';
---

<div id="floating-island">
	<a href="/" class="island-logo" aria-label="Home">
		<Image src={logoImage} alt="" width={56} height={56} />
	</a>
	<LanguageSelector />
	<a href={backLink} class="island-back-btn" aria-label="Go Back">
		<svg width="24" height="24" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" fill="#000000"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path fill="#000000" fill-rule="evenodd" d="M4.297105,3.29289 L0.59,7 L4.297105,10.7071 C4.687635,11.0976 5.320795,11.0976 5.711315,10.7071 C6.101845,10.3166 6.101845,9.68342 5.711315,9.29289 L4.418425,8 L11.504215,8 C12.332615,8 13.004215,8.67157 13.004215,9.5 C13.004215,10.3284 12.332615,11 11.504215,11 L10.004215,11 C9.451935,11 9.004215,11.4477 9.004215,12 C9.004215,12.5523 9.451935,13 10.004215,13 L11.504215,13 C13.437215,13 15.004215,11.433 15.004215,9.5 C15.004215,7.567 13.437215,6 11.504215,6 L4.418425,6 L5.711315,4.70711 C6.101845,4.31658 6.101845,3.68342 5.711315,3.29289 C5.320795,2.90237 4.687635,2.90237 4.297105,3.29289 Z"></path> </g></svg>
	</a>
</div>

<style>
	#floating-island {
		position: fixed;
		top: 1rem;
		left: 50%;
		transform: translateX(-50%) scale(0.9); /* Start at the same size the header shrinks to */
		z-index: 101;
		width: max-content;
		max-width: calc(100% - 2rem);
		
		display: flex;
		align-items: center;
		gap: 10rem;
		
		background: rgba(245, 241, 235, 0.95);
		box-shadow: 0 8px 32px rgba(0,0,0,0.15);
		border: 4px solid var(--accent);
		border-radius: 100px;
		padding: 0.5rem 1.5rem;
		
		opacity: 0;
		pointer-events: none;
		transition: all 0.3s ease;
	}

	#floating-island.visible {
		opacity: 1;
		pointer-events: auto;
		transform: translateX(-50%) scale(1); /* Grow into place */
		gap: 0.5rem;
	}

	.island-logo img {
		border-radius: 50%;
		transition: transform 0.2s;
		display: block;
	}
	.island-logo:hover img {
		transform: scale(1.1);
	}

	/* Make buttons bigger in the island */
	#floating-island :global(.lang-btn) {
		padding: 1.25rem 1.25rem;
		font-size: 1.1rem;
	}

	#floating-island :global(.language-controls) {
		flex-wrap: nowrap;
	}

	.island-back-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		border-radius: 50%;
		background: transparent;
		color: var(--accent);
		transition: all 0.2s ease;
		margin-left: 0.5rem;
	}
	.island-back-btn:hover {
		transform: scale(1.1);
	}
	.island-back-btn svg,
	.island-back-btn svg path {
		fill: currentColor;
	}

	/* Hide on mobile if you prefer the standard hamburger menu there */
	@media (max-width: 720px) {
		#floating-island {
			display: none !important;
		}
	}
</style>

<script>
	function initializeScrollEffect() {
		const island = document.getElementById('floating-island');
		if (!island) return;
		
		function handleScroll() {
			if (window.scrollY > 50) {
				island.classList.add('visible');
			} else {
				island.classList.remove('visible');
			}
		}

		window.addEventListener('scroll', handleScroll, { passive: true });
		handleScroll(); // Check on load
	}

	document.addEventListener('astro:page-load', initializeScrollEffect);
</script>