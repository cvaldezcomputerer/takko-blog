<div class="diptych">
  <slot />
</div>

<style>
  .diptych {
    display: grid;
    grid-template-columns: 1fr; 
    gap: 1.5rem;
    margin: 2rem 0;
    width: 100%;
  }

  .diptych :global(img),
  .diptych :global(figure) {
    margin: 0;
    width: 100%;
    height: auto;
    object-fit: cover; 
    border-radius: 8px; 
    align-self: start; 
  }

  .diptych :global(figcaption) {
    font-size: 0.9em;
    color: var(--gray);
    margin-top: 0.5rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .diptych {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>