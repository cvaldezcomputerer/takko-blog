---
import LanguageSelector from '../i18n/LanguageSelector.astro';
import SettingsCog from '../settings/SettingsCog.astro';

const backLink = Astro.url.pathname.startsWith('/blog/') && Astro.url.pathname !== '/blog' && Astro.url.pathname !== '/blog/' ? '/' : '/';
---

<button class="ghost-island" data-target="left" aria-label="Move island left"></button>
<button class="ghost-island" data-target="center" aria-label="Move island center"></button>
<button class="ghost-island" data-target="right" aria-label="Move island right"></button>
<button class="ghost-island" data-target="bottom" aria-label="Move island bottom"></button>

<div id="floating-island">
	<a href={backLink} class="island-back-btn" aria-label="Go Back">
		<svg width="24" height="24" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" fill="#000000"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path fill="#000000" fill-rule="evenodd" d="M4.297105,3.29289 L0.59,7 L4.297105,10.7071 C4.687635,11.0976 5.320795,11.0976 5.711315,10.7071 C6.101845,10.3166 6.101845,9.68342 5.711315,9.29289 L4.418425,8 L11.504215,8 C12.332615,8 13.004215,8.67157 13.004215,9.5 C13.004215,10.3284 12.332615,11 11.504215,11 L10.004215,11 C9.451935,11 9.004215,11.4477 9.004215,12 C9.004215,12.5523 9.451935,13 10.004215,13 L11.504215,13 C13.437215,13 15.004215,11.433 15.004215,9.5 C15.004215,7.567 13.437215,6 11.504215,6 L4.418425,6 L5.711315,4.70711 C6.101845,4.31658 6.101845,3.68342 5.711315,3.29289 C5.320795,2.90237 4.687635,2.90237 4.297105,3.29289 Z"></path> </g></svg>
	</a>
	<LanguageSelector />
	<SettingsCog class="island-settings" size="44px" />
</div>

<style>
	:global(html.island-hidden) #floating-island,
	:global(html.island-hidden) .ghost-island {
		display: none !important;
	}

	#floating-island {
		position: fixed;
		top: 1rem;
		z-index: 101;
		width: max-content;
		max-width: calc(100% - 2rem);
		
		display: flex;
		align-items: center;
		gap: 10rem;
		
		background: var(--secondary);
		box-shadow: 0 8px 32px rgba(0,0,0,0.15);
		border: 4px solid var(--accent);
		border-radius: 100px;
		padding: 0.5rem 1.5rem;
		
		opacity: 0;
		pointer-events: none;
		
		left: 50%;
		top: 1rem;
		transform: translateX(-50%) scale(0.9);
		
		/* GPU acceleration - prevent jitter on mobile */
		will-change: transform, opacity;
		backface-visibility: hidden;
		-webkit-backface-visibility: hidden;
		
		
		
		transition: 
			opacity 0.3s ease,
			transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
			left 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
			top 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
			bottom 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
			gap 0.5s ease,
			background-color 0.3s ease,
			border-color 0.3s ease;
	}

	:global(.dark) #floating-island {
		box-shadow: 0 8px 32px rgba(0,0,0,0.5);
	}

	#floating-island.visible {
		opacity: 1;
		pointer-events: auto;
		gap: 0.5rem;
		transform: translateX(-50%) scale(1);
	}
	
	#floating-island[data-position="left"] {
		left: 2rem;
		top: 50%;
		flex-direction: column;
		transform: translate(0, -50%) scale(0.9);
	}
	#floating-island.visible[data-position="left"] {
		transform: translate(0, -50%) scale(1);
	}
	
	#floating-island[data-position="right"] {
		left: 100%;
		top: 50%;
		flex-direction: column;
		transform: translate(calc(-100% - 2rem), -50%) scale(0.9);
	}
	#floating-island.visible[data-position="right"] {
		transform: translate(calc(-100% - 2rem), -50%) scale(1);
	}

	#floating-island[data-position="bottom"] {
		top: auto;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%) scale(0.9);
	}
	#floating-island.visible[data-position="bottom"] {
		transform: translateX(-50%) scale(1);
	}

	#floating-island[data-position="left"] :global(.language-controls),
	#floating-island[data-position="right"] :global(.language-controls) {
		flex-direction: column;
	}

	#floating-island[data-position="left"] :global(.pill-button),
	#floating-island[data-position="right"] :global(.pill-button) {
		width: 100%;
		margin-left: 0;
		margin-top: -1px;
		border-radius: 0;
	}

	#floating-island[data-position="left"] :global(.pill-button:first-child),
	#floating-island[data-position="right"] :global(.pill-button:first-child) {
		border-radius: 9999px 9999px 0 0;
	}

	#floating-island[data-position="left"] :global(.pill-button:last-child),
	#floating-island[data-position="right"] :global(.pill-button:last-child) {
		border-radius: 0 0 9999px 9999px;
	}

	.ghost-island {
		position: fixed;
		border-radius: 20px;
		background: rgba(255, 255, 255, 0.4);
		border: 2px dashed rgba(0,0,0,0.15);
		color: rgba(0,0,0,0.3);
		
		display: flex;
		align-items: center;
		justify-content: center;
		
		cursor: pointer;
		z-index: 100;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.3s ease, transform 0.2s ease, border-color 0.2s, color 0.2s, background-color 0.2s;
		animation: ghostPulse 3s infinite ease-in-out;
	}
	
	:global(.dark) .ghost-island {
		background: rgba(0, 0, 0, 0.4);
		border-color: rgba(255, 255, 255, 0.15);
		color: rgba(255, 255, 255, 0.3);
	}
	

	.ghost-island:hover {
		border-color: var(--accent);
		color: var(--accent);
		background: rgba(255, 255, 255, 0.9);
		animation: none;
	}
	:global(.dark) .ghost-island:hover {
		background: var(--highlight);
		border-color: var(--text);
		color: var(--text);
	}
	
	.ghost-island::after {
		content: '+';
		font-size: 1.5rem;
		font-weight: 700;
		padding-bottom: 2px;
	}

	.ghost-island[data-target="left"] { 
		left: 2rem; 
		top: 50%;
		transform: translateY(-50%);
		width: 40px;
		height: 80px;
	}
	.ghost-island[data-target="left"]:hover { transform: translateY(-50%) scale(1.2); }

	.ghost-island[data-target="center"] { 
		left: 50%; 
		top: 2.25rem; 
		transform: translateX(-50%);
		width: 80px;
		height: 40px;
	}
	.ghost-island[data-target="center"]:hover { transform: translateX(-50%) scale(1.2); }
	
	.ghost-island[data-target="right"] { 
		right: 2rem; 
		top: 50%; 
		transform: translateY(-50%); 
		width: 40px; 
		height: 80px; 
	}
	.ghost-island[data-target="right"]:hover { transform: translateY(-50%) scale(1.2); }

	.ghost-island[data-target="bottom"] {
		left: 50%;
		bottom: 2rem;
		transform: translateX(-50%);
		width: 80px;
		height: 40px;
	}
	.ghost-island[data-target="bottom"]:hover { transform: translateX(-50%) scale(1.2); }

	.ghost-island.visible {
		opacity: 1;
		pointer-events: auto;
	}
	.ghost-island.active-pos {
		opacity: 0;
		pointer-events: none;
	}

	.island-logo :global(.takko-logo) {
		transition: transform 0.2s;
		display: block;
		width: 56px;
		height: 56px;
	}
	.island-logo:hover :global(.takko-logo) {
		transform: scale(1.1);
	}

	#floating-island :global(.lang-btn) {
		padding: 1.25rem 1.25rem;
		font-size: 1.1rem;
	}

	#floating-island :global(.language-controls) {
		flex-wrap: nowrap;
	}

	.island-back-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		border-radius: 50%;
		background: transparent;
		color: var(--accent);
		transition: all 0.2s ease;
		margin-left: 0.5rem;
	}
	.island-back-btn:hover {
		transform: scale(1.1);
	}
	.island-back-btn svg,
	.island-back-btn svg path {
		fill: currentColor;
	}

	.island-settings {
		margin-left: 0.5rem;
	}

	@media (max-width: 720px) {
		.ghost-island[data-target="bottom"] {
			display: flex;
		}
		
		.ghost-island[data-target="left"],
		.ghost-island[data-target="right"] {
			display: none;
		}

		#floating-island {
			width: fit-content;
			max-width: 95%;
			padding: 0.5rem 1rem;
			gap: 0.75rem;
			justify-content: center;
		}

		.island-settings {
			margin-left: 0;
		}

		.island-settings :global(.settings-cog) {
			width: 30px;
			height: 30px;
		}

		.island-settings :global(.settings-cog svg) {
			width: 19px;
			height: 19px;
		}

		.island-settings :global(.settings-panel) {
			right: 0;
			min-width: 210px;
		}
		
		#floating-island :global(.pill-button) {
			padding: 0.5rem 0.5rem;
			font-size: 0.8rem;
		}
		
		.island-logo :global(.takko-logo) {
			width: 40px;
			height: 40px;
		}
		
		.island-back-btn {
			width: 32px;
			height: 32px;
		}
	}
</style>

<script>
		type IslandPosition = 'left' | 'center' | 'right' | 'bottom';

		function initializeScrollEffect() {
			const island = document.getElementById('floating-island');
			const ghosts = document.querySelectorAll<HTMLElement>('.ghost-island');
			if (!island) return;
		
		function handleScroll() {
			if (window.scrollY > 50) {
				island.classList.add('visible');
				ghosts.forEach(g => g.classList.add('visible'));
			} else {
				island.classList.remove('visible');
				ghosts.forEach(g => g.classList.remove('visible'));

				// If settings was opened from the island, close it when the island auto-hides.
				const islandSettingsWrapper = island.querySelector('.settings-cog-wrapper.is-open');
				if (islandSettingsWrapper) {
					document.dispatchEvent(new CustomEvent('takko:settings-close'));
				}
			}
		}
		
			function setPosition(pos: IslandPosition) {
				island.setAttribute('data-position', pos);
				ghosts.forEach(g => {
					if (g.getAttribute('data-target') === pos) {
					g.classList.add('active-pos');
				} else {
					g.classList.remove('active-pos');
				}
			});
		}
			
			ghosts.forEach(g => {
				g.addEventListener('click', () => {
					const target = g.getAttribute('data-target');
					if (target === 'left' || target === 'center' || target === 'right' || target === 'bottom') {
						setPosition(target);
					}
				});
			});
		
		setPosition('center');

		window.addEventListener('scroll', handleScroll, { passive: true });
		handleScroll();
	}

	document.addEventListener('astro:page-load', initializeScrollEffect);
</script>
