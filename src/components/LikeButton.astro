---
const { slug } = Astro.props;
---

<like-button data-slug={slug}>
  <span class="count">...</span>
  <button aria-label="Like this post">
   
    <svg class="cat-icon" width="1024" height="1024" viewBox="0 0 1024 1024" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g id="cat-logo">
        <g id="head">
          <path d="M199 468C257.592 409.289 296.829 383.891 378 352M199 468C174.118 374.842 171 252.5 187 231C206 224.5 320.888 290.902 378 352M199 468C136.885 532.312 124 583 143 680C191.5 772 243 783 346 792C399.466 819.505 433 839 502 839C579 836 598.935 822.763 652.5 792C784.385 779.941 838 749 863 648.5C866 571.5 847.902 515.187 795.5 461.5M378 352C408.38 336.495 421.494 325.085 439.5 301C455.5 265.5 465.5 227.5 465.5 191L531 147C522.5 204.5 543.23 277.333 567 312C586.176 332.053 597.464 341.182 620 348M620 348C706.5 271.5 788 231 814 236.5C826 252.5 824.561 374.668 795.5 461.5M620 348C693.486 383.276 731.75 408.424 795.5 461.5" stroke="currentColor" stroke-width="17" stroke-linejoin="round" stroke-linecap="round"/>
        </g>
        <g id="right-eye">
          <path class="eye-lid" d="M575 524H694" stroke="currentColor" stroke-width="22" stroke-linecap="round" fill="none"/>
          <path class="eye-pupil" d="M638 524V635.5" stroke="currentColor" stroke-width="22" stroke-linecap="round" fill="none"/>
        </g>
        <g id="left-eye">
          <path class="eye-lid" d="M296.5 523.5H415.5" stroke="currentColor" stroke-width="22" stroke-linecap="round" fill="none"/>
          <path class="eye-pupil" d="M359.5 523.5V635" stroke="currentColor" stroke-width="22" stroke-linecap="round" fill="none"/>
        </g>
        <g id="whiskers">
          <path id="left-whisker" d="M191 587.5L271 600.5M189.5 667L271 651.5" stroke="currentColor" stroke-width="20" stroke-linecap="round" fill="none"/>
          <path id="right-whisker" d="M801 588L721 601M802.5 667.5L721 652" stroke="currentColor" stroke-width="20" stroke-linecap="round" fill="none"/>
        </g>
        <g id="mouth-nose">
          <path id="nose" d="M510 626H485.5L488 645L498.5 654.5L508.5 645L510 626Z" fill="currentColor"/>
          <path id="mouth" d="M451 714.5C470.702 710.853 481.081 703.062 498.5 690M498.5 690C515.387 703.979 525.654 711.774 545.5 714.5M498.5 690V654.5M498.5 654.5L488 645L485.5 626H510L508.5 645L498.5 654.5Z" stroke="currentColor" stroke-width="13" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </g>
      </g>
    </svg>
  </button>

</like-button>

<script>
  // We define a custom element. This is the "Astro way" to do vanilla JS islands.
  // It ensures the code runs only when the component is present on the page.
  class LikeButton extends HTMLElement {
    constructor() {
      super();
      // Wait for children to be parsed to avoid null errors
      setTimeout(() => {
      const slug = this.dataset.slug;
      const btn = this.querySelector('button');
      const countSpan = this.querySelector('.count');
      const catIcon = this.querySelector('.cat-icon');

      // Random pastel background color for the balloon
      const hue = Math.floor(Math.random() * 360);
      countSpan.style.backgroundColor = `hsl(${hue}, 85%, 90%)`;
      
      this.hasLiked = false;
      this.balloonClicks = 0;
      this.deflateTimer = null;

      // 1. Fetch the current like count on load
      fetch(`/api/likes/${slug}`)
        .then(async res => {
          if (!res.ok) throw new Error(await res.text());
          return res.json();
        })
        .then(data => {
          countSpan.textContent = data.count;
        })
        .catch(e => console.error("Failed to fetch likes", e));

      // 2. Handle the click
      btn.addEventListener('click', () => {
        if (this.deflateTimer) clearTimeout(this.deflateTimer);

        if (!this.hasLiked) {
          this.hasLiked = true;
          this.sendLike(slug, countSpan);
          return;
        }

        // Balloon logic
        this.balloonClicks++;

        if (this.balloonClicks >= 10) {
          // Pop!
          this.balloonClicks = 0;
          btn.style.transform = 'scale(1)';
          catIcon.style.fill = 'none';
          // Simple pop animation
          btn.animate([
            { transform: 'scale(1.5)', opacity: 0.8 },
            { transform: 'scale(1)', opacity: 1 }
          ], { duration: 300, easing: 'ease-out' });
          
          this.sendLike(slug, countSpan);
        } else {
          // Inflate
          const scale = 1 + (this.balloonClicks * 0.1);
          btn.style.transform = `scale(${scale})`;
          
          // Deflate after 1 second of inactivity
          this.deflateTimer = setTimeout(() => {
            this.balloonClicks = 0;
            btn.style.transform = 'scale(1)';
            catIcon.style.fill = 'none';
          }, 1000);
        }
      });
      }, 0);
    }

    sendLike(slug, countSpan) {
      const current = parseInt(countSpan.textContent) || 0;
      countSpan.textContent = current + 1;

      fetch(`/api/likes/${slug}`, { method: 'POST' })
        .then(async res => {
          if (!res.ok) throw new Error(await res.text());
          return res.json();
        })
        .then(data => { countSpan.textContent = data.count; })
        .catch(e => console.error("Failed to update likes", e));
    }
  }

  customElements.define('like-button', LikeButton);
</script>

<style>
  like-button {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  button {
    /* Custom SVG cursor (Open Hand) to bypass driver glitches */
    cursor: url("data:image/svg+xml;utf8,<svg viewBox='-10 -10 50 50' fill='%23ffffff' xmlns='http://www.w3.org/2000/svg' transform='rotate(45)'><g id='SVGRepo_bgCarrier' stroke-width='0'></g><g id='SVGRepo_tracerCarrier' stroke-linecap='round' stroke-linejoin='round' stroke='%23df3030' stroke-width='0.048'></g><g id='SVGRepo_iconCarrier'> <path d='M17 11V9.27308C17 8.75533 17.2588 8.27183 17.6896 7.98463L17.7388 7.95181C18.2041 7.64162 18.806 7.62565 19.287 7.91073V7.91073C19.729 8.17263 20 8.64824 20 9.16196L20 13C20 14.6997 19.4699 16.2756 18.5661 17.5714C17.1204 19.6439 14.7186 21 12 21C9.28145 21 6.8796 19.6439 5.43394 17.5714C4.53009 16.2756 4.00001 14.6997 4.00001 13L4.00001 12.2117C4 11.438 4.44632 10.7336 5.14599 10.4032V10.4032C5.6867 10.1479 6.3133 10.1479 6.85401 10.4032V10.4032C7.55368 10.7336 8 11.438 8.00001 12.2117L8.00001 13' stroke='%23323232' stroke-width='2.4' stroke-linecap='round'></path> <path d='M8 12V5.80278C8 5.30125 8.25065 4.8329 8.66795 4.5547V4.5547C9.1718 4.2188 9.8282 4.2188 10.3321 4.5547V4.5547C10.7493 4.8329 11 5.30125 11 5.80278V11' stroke='%23323232' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'></path> <path d='M14 11V5.80278C14 5.30125 14.2507 4.8329 14.6679 4.5547V4.5547C15.1718 4.2188 15.8282 4.2188 16.3321 4.5547V4.5547C16.7493 4.8329 17 5.30125 17 5.80278V9' stroke='%23323232' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'></path> <path d='M11 6V4.80278C11 4.30125 11.2507 3.8329 11.6679 3.5547V3.5547C12.1718 3.2188 12.8282 3.2188 13.3321 3.5547V3.5547C13.7493 3.8329 14 4.30125 14 4.80278V6' stroke='%23323232' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'></path> </g></svg>") 16 16, pointer;
    border: none;
    background: transparent;
    padding: 0;
    width: 60px;
    height: 60px;
    transition: background-color 0.2s, transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.15));
  }
  button:active {
    /* Custom SVG cursor (Grabbing Hand) */
    cursor: url("data:image/svg+xml;utf8,<svg viewBox='-10 -10 50 50' fill='%23ffffff' xmlns='http://www.w3.org/2000/svg' transform='rotate(45)'><g id='SVGRepo_bgCarrier' stroke-width='0'></g><g id='SVGRepo_tracerCarrier' stroke-linecap='round' stroke-linejoin='round' stroke='%23df3030' stroke-width='0.048'></g><g id='SVGRepo_iconCarrier'> <path d='M17 11V9.27308C17 8.75533 17.2588 8.27183 17.6896 7.98463L17.7388 7.95181C18.2041 7.64162 18.806 7.62565 19.287 7.91073V7.91073C19.729 8.17263 20 8.64824 20 9.16196L20 13C20 14.6997 19.4699 16.2756 18.5661 17.5714C17.1204 19.6439 14.7186 21 12 21C9.28145 21 6.8796 19.6439 5.43394 17.5714C4.53009 16.2756 4.00001 14.6997 4.00001 13L4.00001 12.2117C4 11.438 4.44632 10.7336 5.14599 10.4032V10.4032C5.6867 10.1479 6.3133 10.1479 6.85401 10.4032V10.4032C7.55368 10.7336 8 11.438 8.00001 12.2117L8.00001 13' stroke='%23323232' stroke-width='2.4' stroke-linecap='round'></path> <path d='M8 12V5.80278C8 5.30125 8.25065 4.8329 8.66795 4.5547V4.5547C9.1718 4.2188 9.8282 4.2188 10.3321 4.5547V4.5547C10.7493 4.8329 11 5.30125 11 5.80278V11' stroke='%23323232' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'></path> <path d='M14 11V5.80278C14 5.30125 14.2507 4.8329 14.6679 4.5547V4.5547C15.1718 4.2188 15.8282 4.2188 16.3321 4.5547V4.5547C16.7493 4.8329 17 5.30125 17 5.80278V9' stroke='%23323232' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'></path> <path d='M11 6V4.80278C11 4.30125 11.2507 3.8329 11.6679 3.5547V3.5547C12.1718 3.2188 12.8282 3.2188 13.3321 3.5547V3.5547C13.7493 3.8329 14 4.30125 14 4.80278V6' stroke='%23323232' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'></path> </g></svg>") 16 16, grabbing;
  }
  button:hover .cat-icon {
    filter: brightness(0.95);
  }
  .count {
    font-size: 0.8rem;
    font-weight: bold;
    color: #333;
    background: #fafafa;
    border: 2px solid #888;
    padding: 4px 8px;
    border-radius: 20px;
    
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    position: relative;
    margin-bottom: 8px;
  }
  /* The knot of the balloon */
  .count::before {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border-left: 3px solid transparent;
    border-right: 3px solid transparent;
    border-top: 4px solid #888;
  }
  /* The string */
  .count::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 10px;
    background: #888;
    z-index: -1;
  }
  .cat-icon {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    fill: none;
    stroke: rgb(var(--gray));
  }

  /* Eye Interaction */
  .eye-pupil, .eye-lid {
    transition: transform 0.2s ease-in-out;
  }
  .eye-pupil {
    transform-box: fill-box;
    transform-origin: center;
  }
  .eye-lid {
    transform-box: view-box;
  }
  button:hover .eye-pupil {
    transform: scaleY(0);
  }
  button:hover .eye-lid {
    transform: translateY(5.5%);
  }
</style>