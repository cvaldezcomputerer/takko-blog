---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import LanguageSelector from './LanguageSelector.astro';
import T from './T.astro';
import Logo from './Logo.astro';
import FloatingIsland from './FloatingIsland.astro';
import ThemeToggle from './ThemeToggle.astro';
import SettingsCog from './SettingsCog.astro';
---

<header>
	<nav>
		
		<a href="/" class="logo-link">
			<Logo />
			<span class="site-title-text">{SITE_TITLE}</span>
		</a>

		<LanguageSelector />
		<ThemeToggle />
		<SettingsCog class="header-settings" size="40px" />
		
		<div class="menu-content">
			<div class="internal-links">
				<HeaderLink href="/">
					<T fluid>
						<span slot="en">Blog</span>
						<span slot="ja">ブログ</span>
						<span slot="en_simple">📖 <span class="nav-text">Blog</span></span>
					</T>
				</HeaderLink>
				<HeaderLink href="/about">
					<T fluid>
						<span slot="en">About</span>
						<span slot="ja">プロフィール</span>
						<span slot="en_simple">👋 <span class="nav-text">About</span></span>
					</T>
				</HeaderLink>
				<HeaderLink href="/contact/">
					<T fluid>
						<span slot="en">Contact</span>
						<span slot="ja">コンタクト</span>
						<span slot="en_simple">📬 <span class="nav-text">Contact</span></span>
					</T>
				</HeaderLink>
			</div>
		</div>
		<button class="hamburger-menu" aria-label="Open menu" aria-expanded="false">
			<svg class="icon-hamburger" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
			<svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
		</button>
	</nav>
</header>
<FloatingIsland />

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--secondary);
		border-top: 4px solid var(--accent); 
		box-shadow: 0 2px 12px rgba(0, 0, 0, 8%); 
		z-index: 100;
		position: sticky;
		top: 0;
		transition: all 0.3s ease;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 1em;
		position: relative;
		justify-content: space-between;
	}
	.logo-link {
		display: flex;
		align-items: center;
		gap: 0.75em;
		padding: 0.5em 0;
		text-decoration: none;
		font-size: 1.125em;
		font-weight: 600;
		color: rgb(var(--black));
		flex-shrink: 0;
		transition: transform 0.3s ease, color 0.3s ease;
	}
	.logo-link :global(.takko-logo) {
		height: 2.5em;
		width: auto;
		transition: all 0.3s ease;
	}
	.logo-link:hover :global(.takko-logo) {
		transform: scale(1.1);
	}
	.logo-link.is-sleeping :global(.takko-logo) {
		animation: logo-breathe 3.8s ease-in-out infinite;
		transform-origin: center;
	}
	.site-title-text {
		transition: all 0.3s ease;
		opacity: 1;
		max-width: 400px;
		overflow: hidden;
		white-space: nowrap;
	}
	@keyframes logo-breathe {
		0%, 100% {
			transform: scale(1);
		}
		50% {
			transform: scale(1.03);
		}
	}

	.hamburger-menu {
		display: none;
		padding: 0.5rem;
		border: none;
		background: none;
		cursor: pointer;
		z-index: 20;
		color: var(--accent);
	}
	.hamburger-menu .icon-close {
		display: none;
	}
	.is-menu-open .hamburger-menu .icon-close {
		display: block;
	}
	.is-menu-open .hamburger-menu .icon-hamburger {
		display: none;
	}

	.menu-content {
		display: flex;
		justify-content: flex-end;
		align-items: center;
		flex-grow: 1;
		transition: transform 0.3s ease;
	}
	
	@media (min-width: 1400px) {
		nav :global(.language-controls) {
			position: absolute;
			left: 50%;
			transform: translateX(-50%);
		}
	}
	.internal-links {
		display: flex;
		gap: 1em;
		align-items: center;
		border-left: 1px solid rgba(var(--gray), 25%);
		padding-left: 1.5em;
		transition: all 0.3s ease;
		
	}
	.social-links {
		display: flex;
		
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	.internal-links :global(a) {
		transition: all 0.3s ease;
		opacity: 1;
		max-width: 200px;
		overflow: hidden;
		white-space: nowrap;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

	@media (max-width: 1200px) {
		.nav-text {
			display: none;
		}
	}
	@media (max-width: 720px) {
		.nav-text {
			display: inline;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.logo-link.is-sleeping :global(.takko-logo) {
			animation: none;
		}
	}

	@media (max-width: 720px) {
		:global(theme-toggle) {
			display: none;
		}

		.hamburger-menu {
			display: block;
		}
		.menu-content {
			display: none;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			background: var(--secondary);
			box-shadow: var(--box-shadow);
			padding: 1rem;
			margin-inline: 0; 
		}
		.is-menu-open .menu-content {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1.5rem;
		}
		.internal-links {
			flex-direction: column;
			align-items: center;
			width: 100%;
		}
		.social-links {
            border-left: none; 
            padding-left: 0;
            margin-top: 0.5rem; 
        }
        .internal-links a {
            padding: 0.75rem 1rem; 
            border-radius: 0.375rem; 
            transition: background-color 0.2s;
        }
        .internal-links a:hover {
            background-color: var(--highlight); 
        }
		.site-title-text {
			display: none;
		}
	}

	header.is-scrolled {
		opacity: 0;
		pointer-events: none;
		transform: translateY(1rem) scale(0.9);
	}

	@media (min-width: 721px) {
		header.is-scrolled .logo-link {
			transform: translateX(3rem);
		}
		header.is-scrolled .menu-content {
			transform: translateX(-3rem);
		}
	}
</style>

<script>
	function initializeHamburgerMenu() {
		const hamburgerButton = document.querySelector('.hamburger-menu');
		const header = document.querySelector('header');

		if (hamburgerButton && header) {
			hamburgerButton.addEventListener('click', () => {
				const isMenuOpen = header.classList.toggle('is-menu-open');
				hamburgerButton.setAttribute('aria-expanded', String(isMenuOpen));
			});
		}
	}

	let cleanupScroll;
	let cleanupIdleSleep;

	function initializeScrollEffect() {
		if (cleanupScroll) {
			cleanupScroll();
			cleanupScroll = null;
		}

		const header = document.querySelector('header');
		if (!header) return;
		
		function handleScroll() {
			const islandVisible = window.TakkoSettings ? window.TakkoSettings.getIslandVisibility() : true;
			if (!islandVisible) {
				header.classList.remove('is-scrolled');
				return;
			}

			if (window.scrollY > 50) {
				header.classList.add('is-scrolled');
			} else {
				header.classList.remove('is-scrolled');
			}
		}

		window.addEventListener('scroll', handleScroll, { passive: true });
		document.addEventListener('takko:settings-change', handleScroll);
		cleanupScroll = () => {
			window.removeEventListener('scroll', handleScroll);
			document.removeEventListener('takko:settings-change', handleScroll);
		};
		handleScroll();
	}

	function initializeIdleSleepEffect() {
		if (cleanupIdleSleep) {
			cleanupIdleSleep();
			cleanupIdleSleep = null;
		}

		const header = document.querySelector('header');
		const logoLink = document.querySelector('.logo-link');
		if (!logoLink || !header) return;

		const isLikelyMobile = window.matchMedia('(hover: none), (pointer: coarse)').matches;
		if (isLikelyMobile) return;

		const idleDelayMs = 30000;
		const blinkDurationMs = 520;
		const minPointerMoveResetMs = 250;
		let sleepTimer;
		let blinkTimer;
		let lastPointerMoveResetAt = 0;
		let isPausedForScroll = false;
		const interactionEvents = ['pointermove', 'pointerdown', 'keydown', 'wheel', 'touchstart', 'scroll'];

		function pauseSleepEffect() {
			isPausedForScroll = true;
			logoLink.classList.remove('is-blinking');
			logoLink.classList.remove('is-sleeping');
			window.clearTimeout(blinkTimer);
			window.clearTimeout(sleepTimer);
		}

		function enterSleep() {
			if (logoLink.classList.contains('is-sleeping') || logoLink.classList.contains('is-blinking')) return;
			logoLink.classList.add('is-blinking');
			window.clearTimeout(blinkTimer);
			blinkTimer = window.setTimeout(() => {
				logoLink.classList.remove('is-blinking');
				logoLink.classList.add('is-sleeping');
			}, blinkDurationMs);
		}

		function wakeAndResetTimer(event) {
			if (header.classList.contains('is-scrolled')) {
				pauseSleepEffect();
				return;
			}

			if (event?.type === 'pointermove') {
				const now = Date.now();
				if (now - lastPointerMoveResetAt < minPointerMoveResetMs) return;
				lastPointerMoveResetAt = now;
			}

			isPausedForScroll = false;
			logoLink.classList.remove('is-blinking');
			logoLink.classList.remove('is-sleeping');
			window.clearTimeout(blinkTimer);
			window.clearTimeout(sleepTimer);
			sleepTimer = window.setTimeout(enterSleep, idleDelayMs);
		}

		function syncWithHeaderState() {
			if (header.classList.contains('is-scrolled')) {
				pauseSleepEffect();
				return;
			}

			if (isPausedForScroll) {
				wakeAndResetTimer();
			}
		}

		for (const eventName of interactionEvents) {
			window.addEventListener(eventName, wakeAndResetTimer, { passive: true });
		}

		window.addEventListener('scroll', syncWithHeaderState, { passive: true });
		document.addEventListener('visibilitychange', wakeAndResetTimer);
		wakeAndResetTimer();

		cleanupIdleSleep = () => {
			window.clearTimeout(blinkTimer);
			window.clearTimeout(sleepTimer);
			for (const eventName of interactionEvents) {
				window.removeEventListener(eventName, wakeAndResetTimer);
			}
			window.removeEventListener('scroll', syncWithHeaderState);
			document.removeEventListener('visibilitychange', wakeAndResetTimer);
		};
	}

	document.addEventListener('astro:page-load', () => {
		initializeHamburgerMenu();
		initializeScrollEffect();
		initializeIdleSleepEffect();
	});
</script>
