---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import LanguageSelector from './LanguageSelector.astro';
import T from './T.astro';
import Logo from './Logo.astro';
import FloatingIsland from './FloatingIsland.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header>
	<nav>
		
		<a href="/" class="logo-link">
			<Logo />
			<span class="site-title-text">{SITE_TITLE}</span>
		</a>

		<LanguageSelector />
		<ThemeToggle />
		
		<div class="menu-content">
			<div class="internal-links">
				<HeaderLink href="/">
					<T fluid>
						<span slot="en">Home</span>
						<span slot="ja">ホーム</span>
						<span slot="en_simple">🏠 <span class="nav-text">Home</span></span>
					</T>
				</HeaderLink>
				<HeaderLink href="/blog">
					<T fluid>
						<span slot="en">Blog</span>
						<span slot="ja">ブログ</span>
						<span slot="en_simple">📖 <span class="nav-text">Blog</span></span>
					</T>
				</HeaderLink>
				<HeaderLink href="/about">
					<T fluid>
						<span slot="en">About</span>
						<span slot="ja">プロフィール</span>
						<span slot="en_simple">👋 <span class="nav-text">About</span></span>
					</T>
				</HeaderLink>
				<HeaderLink href="/contact">
					<T fluid>
						<span slot="en">Contact</span>
						<span slot="ja">コンタクト</span>
						<span slot="en_simple">📬 <span class="nav-text">Contact</span></span>
					</T>
				</HeaderLink>
			</div>
		</div>
		<button class="hamburger-menu" aria-label="Open menu" aria-expanded="false">
			<svg class="icon-hamburger" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
			<svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
		</button>
	</nav>
</header>
<FloatingIsland />

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--secondary);
		border-top: 4px solid var(--accent); 
		box-shadow: 0 2px 12px rgba(var(--black), 8%); 
		z-index: 100;
		position: sticky;
		top: 0;
		transition: all 0.3s ease;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 1em;
		position: relative;
		justify-content: space-between;
	}
	.logo-link {
		display: flex;
		align-items: center;
		gap: 0.75em;
		padding: 0.5em 0;
		text-decoration: none;
		font-size: 1.125em;
		font-weight: 600;
		color: rgb(var(--black));
		flex-shrink: 0;
		transition: transform 0.3s ease, color 0.3s ease;
	}
	.logo-link :global(.takko-logo) {
		height: 2.5em;
		width: auto;
		transition: all 0.3s ease;
	}
	.logo-link:hover :global(.takko-logo) {
		transform: scale(1.1);
	}
	.site-title-text {
		transition: all 0.3s ease;
		opacity: 1;
		max-width: 400px;
		overflow: hidden;
		white-space: nowrap;
	}

	/* Hamburger Menu Button */
	.hamburger-menu {
		display: none;
		padding: 0.5rem;
		border: none;
		background: none;
		cursor: pointer;
		z-index: 20;
	}
	.hamburger-menu .icon-close {
		display: none;
	}
	.is-menu-open .hamburger-menu .icon-close {
		display: block;
	}
	.is-menu-open .hamburger-menu .icon-hamburger {
		display: none;
	}

	/* Desktop nav */
	.menu-content {
		display: flex;
		justify-content: flex-end;
		align-items: center;
		flex-grow: 1;
		transition: transform 0.3s ease;
	}
	
	@media (min-width: 1400px) {
		nav :global(.language-controls) {
			position: absolute;
			left: 50%;
			transform: translateX(-50%);
		}
	}
	.internal-links {
		display: flex;
		gap: 1em;
		align-items: center;
		border-left: 1px solid rgba(var(--gray), 25%);
		padding-left: 1.5em;
		transition: all 0.3s ease;
		
	}
	.social-links {
		display: flex;
		
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	.internal-links :global(a) {
		transition: all 0.3s ease;
		opacity: 1;
		max-width: 200px;
		overflow: hidden;
		white-space: nowrap;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

	/* Hide text label next to emoji on intermediate screens */
	@media (max-width: 1200px) {
		.nav-text {
			display: none;
		}
	}
	@media (max-width: 720px) {
		.nav-text {
			display: inline;
		}
	}

	/* Mobile Styles */
	@media (max-width: 720px) {
		.hamburger-menu {
			display: block;
		}
		/* --- CSS FIX: Hide the entire menu content wrapper --- */
		.menu-content {
			display: none;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			background: var(--secondary);
			box-shadow: var(--box-shadow);
			padding: 1rem;
			margin-inline: 0; /* Reset the auto margin */
		}
		/* --- CSS FIX: When open, show it as a vertical list --- */
		.is-menu-open .menu-content {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1.5rem;
		}
		.internal-links {
			flex-direction: column;
			align-items: center;
			width: 100%;
		}
		.social-links {
    border-left: none; /* Remove separator on mobile */
    padding-left: 0;
    margin-top: 0.5rem; /* Add space from nav links */
  }
  .internal-links a {
    padding: 0.75rem 1rem; /* Better touch targets */
    border-radius: 0.375rem; /* Rounded corners */
    transition: background-color 0.2s;
  }
  .internal-links a:hover {
    background-color: var(--highlight); /* Hover feedback */
  }
		.site-title-text {
			display: none;
		}
	}

	/* Desktop Morphing Effect */
	@media (min-width: 721px) {
		header.is-scrolled {
			opacity: 0;
			pointer-events: none;
			transform: translateY(1rem) scale(0.9); /* Shrink and move down towards island */
		}
		header.is-scrolled .logo-link {
			transform: translateX(3rem);
		}
		header.is-scrolled .menu-content {
			transform: translateX(-3rem);
		}
	}
</style>

<script>
	function initializeHamburgerMenu() {
		const hamburgerButton = document.querySelector('.hamburger-menu');
		const header = document.querySelector('header');

		if (hamburgerButton && header) {
			hamburgerButton.addEventListener('click', () => {
				const isMenuOpen = header.classList.toggle('is-menu-open');
				hamburgerButton.setAttribute('aria-expanded', String(isMenuOpen));
			});
		}
	}

	// Variable to track the cleanup function for the scroll listener
	let cleanupScroll;

	function initializeScrollEffect() {
		// 1. Clean up the previous listener if it exists
		if (cleanupScroll) {
			cleanupScroll();
			cleanupScroll = null;
		}

		const header = document.querySelector('header');
		if (!header) return;
		
		function handleScroll() {
			if (window.scrollY > 50) {
				header.classList.add('is-scrolled');
			} else {
				header.classList.remove('is-scrolled');
			}
		}

		window.addEventListener('scroll', handleScroll, { passive: true });
		cleanupScroll = () => window.removeEventListener('scroll', handleScroll);
		handleScroll();
	}

	// Initialize on page load (runs on first load and after navigation)
	document.addEventListener('astro:page-load', () => {
		initializeHamburgerMenu();
		initializeScrollEffect();
	});
</script>