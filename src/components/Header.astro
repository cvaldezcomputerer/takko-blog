---
import { Image } from 'astro:assets';
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import logoImage from '../assets/images/logo.png';
---

<header>
	<nav>
		
		<a href="/" class="logo-link">
			<Image
				src={logoImage}
				alt="Takko Blog homepage"
				width={100}
				height={100}
			/>
			<span class="site-title-text">{SITE_TITLE}</span>
		</a>

		
		<div class="menu-content">
			<div class="internal-links">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/blog">Blog</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
				<HeaderLink href="/contact">Contact</HeaderLink>
			</div>

			<div class="social-links">
				<a href="https://www.youtube.com/@takkotaco" target="_blank">
					<span class="sr-only">my youtube channel</span>
					<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
						<path
							fill="currentColor"
							d="M15.75 4.8s-.18-1.28-.73-1.83c-.6-.55-1.25-.55-1.56-.6C11.2 2.3 8 2.3 8 2.3s-3.2 0-5.46.07c-.3.05-.96-.05-1.56-.6C.43 3.52.25 4.8.25 4.8S.07 6.3.07 7.8v.4c0 1.5 0 3 .07 3s.18 1.28.73 1.83c.6.55 1.25-.55 1.56.6C4.8 13.7 8 13.7 8 13.7s3.2 0 5.46-.07c.3-.05.96-.05 1.56-.6.55-.55.73-1.83.73-1.83S15.93 9.7 15.93 8.2v-.4c0-1.5 0-3-.07-3zM6.41 10.3V5.7l4.5 2.3-4.5 2.3z"
						></path>
					</svg>
				</a>
			</div>
		</div>
		<button class="hamburger-menu" aria-label="Open menu" aria-expanded="false">
			<svg class="icon-hamburger" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
			<svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
		</button>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #f5f1eb; /* Warm beige-brown background */
		border-top: 4px solid var(--accent); /* Green top accent border */
		box-shadow: 0 2px 12px rgba(var(--black), 8%); /* Enhanced shadow for better separation */
		position: relative;
		z-index: 10;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;

	}
	.logo-link {
		display: flex;
		align-items: center;
		gap: 0.75em;
		padding: 0.5em 0;
		text-decoration: none;
		font-size: 1.125em;
		font-weight: 600;
		color: var(--black);
		flex-shrink: 0;
	}
	.logo-link img {
		height: 2.5em;
		width: auto;
		border-radius: 9999px;
	}

	/* Hamburger Menu Button */
	.hamburger-menu {
		display: none;
		padding: 0.5rem;
		border: none;
		background: none;
		cursor: pointer;
		z-index: 20;
	}
	.hamburger-menu .icon-close {
		display: none;
	}
	.is-menu-open .hamburger-menu .icon-close {
		display: block;
	}
	.is-menu-open .hamburger-menu .icon-hamburger {
		display: none;
	}

	/* Desktop Styles for Links */
	.menu-content {
		display: flex;
		align-items: center;
		gap: 2em; 
		
		
	}
	.internal-links {
		display: flex;
		gap: 1em;
		align-items: center;
		border-left: 1px solid #e5e7eb;
		padding-left: 1.5em;
		
	}
	.social-links {
		display: flex;
		
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

	/* Mobile Styles */
	@media (max-width: 720px) {
		.hamburger-menu {
			display: block;
		}
		/* --- CSS FIX: Hide the entire menu content wrapper --- */
		.menu-content {
			display: none;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			background: white;
			box-shadow: 0 4px 8px rgba(var(--black), 10%);
			padding: 1rem;
			margin-inline: 0; /* Reset the auto margin */
		}
		/* --- CSS FIX: When open, show it as a vertical list --- */
		.is-menu-open .menu-content {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1.5rem;
		}
		.internal-links {
			flex-direction: column;
			align-items: center;
			width: 100%;
		}
		.social-links {
    border-left: none; /* Remove separator on mobile */
    padding-left: 0;
    margin-top: 0.5rem; /* Add space from nav links */
  }
  .internal-links a {
    padding: 0.75rem 1rem; /* Better touch targets */
    border-radius: 0.375rem; /* Rounded corners */
    transition: background-color 0.2s;
  }
  .internal-links a:hover {
    background-color: #f3f4f6; /* Hover feedback */
  }
		.site-title-text {
			display: none;
		}
	}
</style>

<script>
	function initializeHamburgerMenu() {
		const hamburgerButton = document.querySelector('.hamburger-menu');
		const header = document.querySelector('header');

		if (hamburgerButton && header) {
			// Remove any existing event listeners first
			hamburgerButton.removeEventListener('click', handleHamburgerClick);
			// Add the event listener
			hamburgerButton.addEventListener('click', handleHamburgerClick);
		}
	}

	function handleHamburgerClick() {
		const header = document.querySelector('header');
		const hamburgerButton = document.querySelector('.hamburger-menu');
		
		if (header && hamburgerButton) {
			const isMenuOpen = header.classList.toggle('is-menu-open');
			hamburgerButton.setAttribute('aria-expanded', String(isMenuOpen));
		}
	}

	// Initialize on page loa
	initializeHamburgerMenu();

	// Re-initialize on Astro page transitions
	document.addEventListener('astro:page-load', initializeHamburgerMenu);
</script>