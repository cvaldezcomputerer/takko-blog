---
import { Image } from 'astro:assets';
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import LanguageSelector from './LanguageSelector.astro';
import T from './T.astro';
import logoImage from '../assets/images/logo.png';

// Determine where the "Back" button should go
// If we are deep in the blog (e.g. /blog/post-1), go back to /blog. Otherwise go Home.
const backLink = Astro.url.pathname.startsWith('/blog/') && Astro.url.pathname !== '/blog' && Astro.url.pathname !== '/blog/' ? '/blog' : '/';
---

<header>
	<nav>
		
		<a href="/" class="logo-link">
			<Image
				src={logoImage}
				alt="Takko Blog homepage"
				width={100}
				height={100}
			/>
			<span class="site-title-text">{SITE_TITLE}</span>
		</a>

		
		<div class="menu-content">
			<LanguageSelector />

			<div class="internal-links">
				<HeaderLink href="/">
					<T>
						<span slot="en">Home</span>
						<span slot="ja">ホーム</span>
						<span slot="en_simple">🏠 <span class="nav-text">Home</span></span>
					</T>
				</HeaderLink>
				<HeaderLink href="/blog">
					<T>
						<span slot="en">Blog</span>
						<span slot="ja">ブログ</span>
						<span slot="en_simple">📖 <span class="nav-text">Blog</span></span>
					</T>
				</HeaderLink>
				<HeaderLink href="/about">
					<T>
						<span slot="en">About</span>
						<span slot="ja">プロフィール</span>
						<span slot="en_simple">👋 <span class="nav-text">About</span></span>
					</T>
				</HeaderLink>
				<HeaderLink href="/contact">
					<T>
						<span slot="en">Contact</span>
						<span slot="ja">コンタクト</span>
						<span slot="en_simple">📬 <span class="nav-text">Contact</span></span>
					</T>
				</HeaderLink>
				
				<!-- Dedicated Back Button (Only visible when scrolled) -->
				<a href={backLink} class="scrolled-back-btn" aria-label="Go Back">
					<svg width="24" height="24" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" fill="#000000"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path fill="#000000" fill-rule="evenodd" d="M4.297105,3.29289 L0.59,7 L4.297105,10.7071 C4.687635,11.0976 5.320795,11.0976 5.711315,10.7071 C6.101845,10.3166 6.101845,9.68342 5.711315,9.29289 L4.418425,8 L11.504215,8 C12.332615,8 13.004215,8.67157 13.004215,9.5 C13.004215,10.3284 12.332615,11 11.504215,11 L10.004215,11 C9.451935,11 9.004215,11.4477 9.004215,12 C9.004215,12.5523 9.451935,13 10.004215,13 L11.504215,13 C13.437215,13 15.004215,11.433 15.004215,9.5 C15.004215,7.567 13.437215,6 11.504215,6 L4.418425,6 L5.711315,4.70711 C6.101845,4.31658 6.101845,3.68342 5.711315,3.29289 C5.320795,2.90237 4.687635,2.90237 4.297105,3.29289 Z"></path> </g></svg>
				</a>
			</div>
		</div>
		<button class="hamburger-menu" aria-label="Open menu" aria-expanded="false">
			<svg class="icon-hamburger" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
			<svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
		</button>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #f5f1eb;
		border-top: 4px solid var(--accent); 
		box-shadow: 0 2px 12px rgba(var(--black), 8%); 
		top: 0;
		z-index: 100;
		position: sticky;
		transition: all 0.3s ease;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 1em;
		position: relative;

	}
	.logo-link {
		display: flex;
		align-items: center;
		gap: 0.75em;
		padding: 0.5em 0;
		text-decoration: none;
		font-size: 1.125em;
		font-weight: 600;
		color: var(--black);
		flex-shrink: 0;
	}
	.logo-link img {
		height: 2.5em;
		width: auto;
		border-radius: 9999px;
		transition: all 0.3s ease;
	}
	.site-title-text {
		transition: all 0.3s ease;
		opacity: 1;
		max-width: 400px;
		overflow: hidden;
		white-space: nowrap;
	}

	/* Hamburger Menu Button */
	.hamburger-menu {
		display: none;
		padding: 0.5rem;
		border: none;
		background: none;
		cursor: pointer;
		z-index: 20;
	}
	.hamburger-menu .icon-close {
		display: none;
	}
	.is-menu-open .hamburger-menu .icon-close {
		display: block;
	}
	.is-menu-open .hamburger-menu .icon-hamburger {
		display: none;
	}

	/* Desktop nav */
	.menu-content {
		display: flex;
		justify-content: flex-end;
		align-items: center;
		flex-grow: 1;
	}
	
	@media (min-width: 1400px) {
		:global(.language-controls) {
			position: absolute;
			left: 50%;
			transform: translateX(-50%);
		}
	}
	.internal-links {
		display: flex;
		gap: 1em;
		align-items: center;
		border-left: 1px solid #e5e7eb;
		padding-left: 1.5em;
		transition: all 0.3s ease;
		
	}
	.social-links {
		display: flex;
		
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	.internal-links :global(a) {
		transition: all 0.3s ease;
		opacity: 1;
		max-width: 200px;
		overflow: hidden;
		white-space: nowrap;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

	/* Hide text label next to emoji on intermediate screens */
	@media (max-width: 1200px) {
		.nav-text {
			display: none;
		}
	}
	@media (max-width: 720px) {
		.nav-text {
			display: inline;
		}
	}

	.scrolled-back-btn {
		display: none;
	}

	/* Mobile Styles */
	@media (max-width: 720px) {
		.hamburger-menu {
			display: block;
		}
		/* --- CSS FIX: Hide the entire menu content wrapper --- */
		.menu-content {
			display: none;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			background: white;
			box-shadow: 0 4px 8px rgba(var(--black), 10%);
			padding: 1rem;
			margin-inline: 0; /* Reset the auto margin */
		}
		/* --- CSS FIX: When open, show it as a vertical list --- */
		.is-menu-open .menu-content {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1.5rem;
		}
		.internal-links {
			flex-direction: column;
			align-items: center;
			width: 100%;
		}
		.social-links {
    border-left: none; /* Remove separator on mobile */
    padding-left: 0;
    margin-top: 0.5rem; /* Add space from nav links */
  }
  .internal-links a {
    padding: 0.75rem 1rem; /* Better touch targets */
    border-radius: 0.375rem; /* Rounded corners */
    transition: background-color 0.2s;
  }
  .internal-links a:hover {
    background-color: #f3f4f6; /* Hover feedback */
  }
		.site-title-text {
			display: none;
		}
	}

	/* --- Focus Mode (Scrolled State) --- */
	@media (min-width: 721px) {
		:global(header.is-scrolled) {
			background: rgba(245, 241, 235, 0.95);
			box-shadow: 0 8px 32px rgba(0,0,0,0.15);
			
			/* Island Styles */
			top: 1rem;
			width: max-content;
			max-width: calc(100% - 2rem);
			margin-inline: auto;
			border-radius: 100px;
			border: 4px solid var(--accent);
			padding: 0.5rem 1.5rem;
			left: 0; right: 0;
		}
		:global(header.is-scrolled) .site-title-text {
			opacity: 0;
			max-width: 0;
			margin: 0;
		}
		:global(header.is-scrolled) .internal-links {
			border-left-color: transparent;
			/* Reset absolute positioning to let it flow in the island */
			position: static;
			padding-left: 0;
			border: none;
			gap: 0;
		}
		/* Show the dedicated back button when scrolled */
		:global(header.is-scrolled) .scrolled-back-btn {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 44px;
			height: 44px;
			border-radius: 50%;
			background: transparent;
			color: var(--accent);
			transition: all 0.2s ease;
			margin-left: 0.5rem;
		}
		:global(header.is-scrolled) .scrolled-back-btn:hover {
			background: var(--accent);
			color: white;
		}
		:global(header.is-scrolled) .scrolled-back-btn svg,
		:global(header.is-scrolled) .scrolled-back-btn svg path {
			fill: currentColor;
		}
		
		/* Hide ALL normal nav links when scrolled */
		:global(header.is-scrolled) .internal-links :global(a:not(.scrolled-back-btn)) {
			opacity: 0;
			max-width: 0;
			padding: 0;
			margin: 0;
			border: 0;
		}
		/* Make buttons bigger */
		:global(header.is-scrolled) :global(.lang-btn) {
			padding: 0.75rem 1.25rem;
			font-size: 1.1rem;
		}
		:global(header.is-scrolled) .menu-content {
			justify-content: center;
			flex-grow: 0;
		}
		/* Reset absolute positioning of language controls in scrolled mode so they flow */
		:global(header.is-scrolled) :global(.language-controls) {
			position: static;
			transform: none;
		}
	}
</style>

<script>
	function initializeHamburgerMenu() {
		const hamburgerButton = document.querySelector('.hamburger-menu');
		const header = document.querySelector('header');

		if (hamburgerButton && header) {
			// Remove any existing event listeners first
			hamburgerButton.removeEventListener('click', handleHamburgerClick);
			// Add the event listener
			hamburgerButton.addEventListener('click', handleHamburgerClick);
		}
	}

	function handleHamburgerClick() {
		const header = document.querySelector('header');
		const hamburgerButton = document.querySelector('.hamburger-menu');
		
		if (header && hamburgerButton) {
			const isMenuOpen = header.classList.toggle('is-menu-open');
			hamburgerButton.setAttribute('aria-expanded', String(isMenuOpen));
		}
	}

	function initializeScrollEffect() {
		const header = document.querySelector('header');
		
		function handleScroll() {
			if (!header) return;
			if (window.scrollY > 20) {
				header.classList.add('is-scrolled');
			} else {
				header.classList.remove('is-scrolled');
			}
		}

		window.addEventListener('scroll', handleScroll);
		handleScroll();
	}

	// Initialize on page loa
	initializeHamburgerMenu();
	initializeScrollEffect();

	// Re-initialize on Astro page transitions
	document.addEventListener('astro:page-load', () => {
		initializeHamburgerMenu();
		initializeScrollEffect();
	});
</script>