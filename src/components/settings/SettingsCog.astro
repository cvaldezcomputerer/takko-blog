---
import T from '../i18n/T.astro';

const { class: className, size = '44px' } = Astro.props;
---

<details class:list={["settings-cog-wrapper", className]} style={`--settings-size: ${size};`}>
  <summary class="settings-cog" aria-label="Open settings">
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"></circle>
      <path d="M3.66122 10.6392C4.13377 10.9361 4.43782 11.4419 4.43782 11.9999C4.43781 12.558 4.13376 13.0638 3.66122 13.3607C3.33966 13.5627 3.13248 13.7242 2.98508 13.9163C2.66217 14.3372 2.51966 14.869 2.5889 15.3949C2.64082 15.7893 2.87379 16.1928 3.33973 16.9999C3.80568 17.8069 4.03865 18.2104 4.35426 18.4526C4.77508 18.7755 5.30694 18.918 5.83284 18.8488C6.07287 18.8172 6.31628 18.7185 6.65196 18.5411C7.14544 18.2803 7.73558 18.2699 8.21895 18.549C8.70227 18.8281 8.98827 19.3443 9.00912 19.902C9.02332 20.2815 9.05958 20.5417 9.15224 20.7654C9.35523 21.2554 9.74458 21.6448 10.2346 21.8478C10.6022 22 11.0681 22 12 22C12.9319 22 13.3978 22 13.7654 21.8478C14.2554 21.6448 14.6448 21.2554 14.8478 20.7654C14.9404 20.5417 14.9767 20.2815 14.9909 19.9021C15.0117 19.3443 15.2977 18.8281 15.7811 18.549C16.2644 18.27 16.8545 18.2804 17.3479 18.5412C17.6837 18.7186 17.9271 18.8173 18.1671 18.8489C18.693 18.9182 19.2249 18.7756 19.6457 18.4527C19.9613 18.2106 20.1943 17.807 20.6603 17C20.8677 16.6407 21.029 16.3614 21.1486 16.1272M20.3387 13.3608C19.8662 13.0639 19.5622 12.5581 19.5621 12.0001C19.5621 11.442 19.8662 10.9361 20.3387 10.6392C20.6603 10.4372 20.8674 10.2757 21.0148 10.0836C21.3377 9.66278 21.4802 9.13092 21.411 8.60502C21.3591 8.2106 21.1261 7.80708 20.6601 7.00005C20.1942 6.19301 19.9612 5.7895 19.6456 5.54732C19.2248 5.22441 18.6929 5.0819 18.167 5.15113C17.927 5.18274 17.6836 5.2814 17.3479 5.45883C16.8544 5.71964 16.2643 5.73004 15.781 5.45096C15.2977 5.1719 15.0117 4.6557 14.9909 4.09803C14.9767 3.71852 14.9404 3.45835 14.8478 3.23463C14.6448 2.74458 14.2554 2.35523 13.7654 2.15224C13.3978 2 12.9319 2 12 2C11.0681 2 10.6022 2 10.2346 2.15224C9.74458 2.35523 9.35523 2.74458 9.15224 3.23463C9.05958 3.45833 9.02332 3.71848 9.00912 4.09794C8.98826 4.65566 8.70225 5.17191 8.21891 5.45096C7.73557 5.73002 7.14548 5.71959 6.65205 5.4588C6.31633 5.28136 6.0729 5.18269 5.83285 5.15108C5.30695 5.08185 4.77509 5.22436 4.35427 5.54727C4.03866 5.78945 3.80569 6.19297 3.33974 7C3.13231 7.35929 2.97105 7.63859 2.85138 7.87273" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
    </svg>
  </summary>
  <div class="settings-panel">
    <p class="settings-title">
      <T fluid>
        <span slot="en">Settings</span>
        <span slot="ja">設定</span>
        <span slot="en_simple">⚙️ Settings</span>
      </T>
    </p>

    <div class="settings-groups">
      <section class="settings-section" aria-label="Study settings">
        <p class="section-title">
          <T fluid>
            <span slot="en">Learn</span>
            <span slot="ja">学習</span>
            <span slot="en_simple">Study</span>
          </T>
        </p>
        <button type="button" class="setting-item" data-setting-toggle="island-visibility">
          <span class="setting-label">
            <T fluid>
              <span slot="en">Island</span>
              <span slot="ja">アイランド表示</span>
              <span slot="en_simple">🏝️ Island</span>
            </T>
          </span>
          <span class="setting-control">
            <span class="setting-value" data-setting-value="island-visibility">On</span>
            <span class="setting-switch" aria-hidden="true"><span class="setting-switch-knob"></span></span>
          </span>
        </button>
        <button type="button" class="setting-item" data-setting-toggle="show-definition-highlights">
          <span class="setting-label">
            <T fluid>
              <span slot="en">Show Explanation</span>
              <span slot="ja">説明を表示</span>
              <span slot="en_simple">📖 Explain</span>
            </T>
          </span>
          <span class="setting-control">
            <span class="setting-value" data-setting-value="show-definition-highlights">On</span>
            <span class="setting-switch" aria-hidden="true"><span class="setting-switch-knob"></span></span>
          </span>
        </button>
      </section>

      <section class="settings-section" aria-label="Site settings">
        <p class="section-title">
          <T fluid>
            <span slot="en">Site</span>
            <span slot="ja">サイト</span>
            <span slot="en_simple">Site</span>
          </T>
        </p>
        <button type="button" class="setting-item" data-setting-toggle="theme">
          <span class="setting-label">
            <T fluid>
              <span slot="en">Dark or Light</span>
              <span slot="ja">テーマ</span>
              <span slot="en_simple">Dark or Light</span>
            </T>
          </span>
          <span class="setting-control">
            <span class="setting-value" data-setting-value="theme">Light</span>
            <span class="setting-switch" aria-hidden="true"><span class="setting-switch-knob"></span></span>
          </span>
        </button>
        <button type="button" class="setting-item" data-setting-toggle="text-size">
          <span class="setting-label">
            <T fluid>
              <span slot="en">Word Size</span>
              <span slot="ja">文字サイズ</span>
              <span slot="en_simple">Word Size</span>
            </T>
          </span>
          <span class="setting-value" data-setting-value="text-size">Medium</span>
        </button>
      </section>
    </div>
  </div>
</details>

<style>
  .settings-cog-wrapper {
    position: relative;
    flex-shrink: 0;
  }

  .settings-cog {
    list-style: none;
    width: var(--settings-size, 44px);
    height: var(--settings-size, 44px);
    border-radius: 50%;
    border: 2px solid rgba(var(--gray), 0.35);
    background: rgba(255, 255, 255, 0.7);
    color: var(--accent);
    display: grid;
    place-items: center;
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
  }

  :global(.dark) .settings-cog {
    background: rgba(0, 0, 0, 0.25);
    border-color: rgba(255, 255, 255, 0.25);
  }

  .settings-cog:hover {
    transform: rotate(12deg) scale(1.05);
    background: var(--highlight);
    border-color: var(--accent);
  }

  .settings-cog-wrapper.is-open .settings-cog {
    transform: rotate(20deg);
  }

  .settings-cog::-webkit-details-marker {
    display: none;
  }

  .settings-cog svg {
    width: 22px;
    height: 22px;
    fill: none;
  }

  .settings-panel {
    display: none;
  }

  .settings-panel.settings-sheet {
    position: fixed;
    left: 50%;
    top: 52%;
    transform: translate(-50%, -50%);
    width: min(92vw, 560px);
    max-height: 80vh;
    overflow: auto;
    background: var(--secondary);
    border: 2px solid var(--accent);
    border-radius: 14px;
    box-shadow: 0 16px 50px rgba(0, 0, 0, 0.25);
    padding: 0.75rem;
    gap: 0.75rem;
    z-index: 350;
  }

  .settings-panel.settings-sheet.is-open {
    display: grid;
  }

  .settings-sheet-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.22);
    backdrop-filter: blur(1px);
    z-index: 340;
    display: none;
  }

  .settings-sheet-backdrop.is-open {
    display: block;
  }

  .settings-title {
    margin: 0;
    font-weight: 700;
    color: var(--accent);
    font-size: 0.95rem;
  }

  .settings-groups {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .settings-section {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
  }

  .settings-section + .settings-section {
    border-left: 1px solid rgba(var(--gray), 0.3);
    padding-left: 0.75rem;
  }

  .section-title {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgb(var(--gray-dark));
    font-weight: 700;
  }

  .settings-panel .setting-item {
    border: 1px solid rgba(var(--gray), 0.35);
    background: var(--background);
    color: rgb(var(--black));
    border-radius: 10px;
    padding: 0.6rem 0.7rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.83rem;
    cursor: pointer;
    gap: 0.75rem;
    min-width: 0;
  }

  .settings-label {
    font-weight: 600;
    color: rgb(var(--black));
    min-width: 0;
  }

  .settings-value {
    color: rgb(var(--gray-dark));
    font-size: 0.78rem;
    white-space: nowrap;
  }

  .setting-control {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  .setting-switch {
    width: 34px;
    height: 20px;
    border-radius: 999px;
    border: 1px solid rgba(var(--gray), 0.45);
    background: rgba(var(--gray), 0.3);
    position: relative;
    transition: background-color 0.2s ease, border-color 0.2s ease;
    flex-shrink: 0;
  }

  .setting-switch-knob {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
    position: absolute;
    top: 2px;
    left: 2px;
    transition: transform 0.2s ease;
  }

  .setting-item[data-on="true"] .setting-switch {
    background: var(--accent);
    border-color: var(--accent);
  }

  .setting-item[data-on="true"] .setting-switch-knob {
    transform: translateX(14px);
  }

  .settings-panel .setting-item:hover {
    border-color: var(--accent);
    background: var(--highlight);
  }

  @media (max-width: 720px) {
    .settings-cog {
      width: 38px;
      height: 38px;
    }

    .settings-cog svg {
      width: 23px;
      height: 23px;
    }

    .settings-panel.settings-sheet {
      width: min(92vw, 340px);
    }

    .settings-groups {
      grid-template-columns: 1fr;
    }

    .settings-section + .settings-section {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid rgba(var(--gray), 0.3);
      padding-top: 0.7rem;
    }
  }
</style>

<script>
  type ThemeMode = 'light' | 'dark';
  type TextSize = 'sm' | 'md' | 'lg';

  function getSettingsState() {
    return window.TakkoSettings ?? null;
  }

  function getCurrentLanguage() {
    const lang = localStorage.getItem('takko-blog-lang');
    return lang === 'ja' || lang === 'en_simple' ? lang : 'en';
  }

  function getToggleValueLabel(isOn: boolean) {
    const lang = getCurrentLanguage();
    if (lang === 'ja') return isOn ? 'オン' : 'オフ';
    return isOn ? 'On' : 'Off';
  }

  function getThemeValueLabel(theme: ThemeMode) {
    const lang = getCurrentLanguage();
    if (lang === 'ja') return theme === 'dark' ? 'ダーク' : 'ライト';
    if (lang === 'en_simple') return theme === 'dark' ? 'Black' : 'White';
    return theme === 'dark' ? 'Dark' : 'Light';
  }

  function getTextSizeValueLabel(size: TextSize) {
    const lang = getCurrentLanguage();
    if (lang === 'ja') return size === 'sm' ? '小' : size === 'lg' ? '大' : '中';
    if (lang === 'en_simple') return size === 'sm' ? 'S' : size === 'lg' ? 'L' : 'M';
    return size === 'sm' ? 'Small' : size === 'lg' ? 'Large' : 'Medium';
  }

  function applyToggleVisual(toggleKey: string, isOn: boolean) {
    const toggleButtons = document.querySelectorAll<HTMLElement>(`[data-setting-toggle="${toggleKey}"]`);
    for (const button of toggleButtons) {
      button.dataset.on = isOn ? 'true' : 'false';
      button.setAttribute('aria-pressed', isOn ? 'true' : 'false');
    }
  }

  function applyShowDefinitionHighlightsSetting() {
    const settings = getSettingsState();
    if (!settings) return;
    const isEnabled = settings.getShowDefinitionHighlights();
    settings.applyDefinitionHighlightsSetting(isEnabled);

    const valueEls = document.querySelectorAll<HTMLElement>('[data-setting-value="show-definition-highlights"]');
    for (const el of valueEls) {
      el.textContent = getToggleValueLabel(isEnabled);
    }
    applyToggleVisual('show-definition-highlights', isEnabled);
  }

  function applyThemeSetting() {
    const settings = getSettingsState();
    if (!settings) return;
    const theme = settings.getTheme();

    const valueEls = document.querySelectorAll<HTMLElement>('[data-setting-value="theme"]');
    for (const el of valueEls) {
      el.textContent = getThemeValueLabel(theme);
    }
    applyToggleVisual('theme', theme === 'dark');
  }

  function applyIslandVisibilitySetting() {
    const settings = getSettingsState();
    if (!settings) return;
    const isVisible = settings.getIslandVisibility();
    settings.applyIslandVisibilitySetting(isVisible);

    const valueEls = document.querySelectorAll<HTMLElement>('[data-setting-value="island-visibility"]');
    for (const el of valueEls) {
      el.textContent = getToggleValueLabel(isVisible);
    }
    applyToggleVisual('island-visibility', isVisible);
  }

  function applyTextSizeSetting() {
    const settings = getSettingsState();
    if (!settings) return;
    const size = settings.getTextSize();
    settings.applyTextSizeSetting(size);

    const label = getTextSizeValueLabel(size);
    const valueEls = document.querySelectorAll<HTMLElement>('[data-setting-value="text-size"]');
    for (const el of valueEls) {
      el.textContent = label;
    }
  }

  function initializeSettingsCogPanels() {
    applyShowDefinitionHighlightsSetting();
    applyThemeSetting();
    applyIslandVisibilitySetting();
    applyTextSizeSetting();

    const toggleButtons = document.querySelectorAll<HTMLElement>('[data-setting-toggle="show-definition-highlights"]');
    for (const button of toggleButtons) {
      if (button.dataset.settingBound) continue;
      button.dataset.settingBound = 'true';
      button.addEventListener('click', () => {
        const settings = getSettingsState();
        if (!settings) return;
        settings.setShowDefinitionHighlights(!settings.getShowDefinitionHighlights());
        applyShowDefinitionHighlightsSetting();
      });
    }

    const themeButtons = document.querySelectorAll<HTMLElement>('[data-setting-toggle="theme"]');
    for (const button of themeButtons) {
      if (button.dataset.settingBound) continue;
      button.dataset.settingBound = 'true';
      button.addEventListener('click', () => {
        const settings = getSettingsState();
        if (!settings) return;
        settings.toggleTheme();
        applyThemeSetting();
      });
    }

    const islandVisibilityButtons = document.querySelectorAll<HTMLElement>('[data-setting-toggle="island-visibility"]');
    for (const button of islandVisibilityButtons) {
      if (button.dataset.settingBound) continue;
      button.dataset.settingBound = 'true';
      button.addEventListener('click', () => {
        const settings = getSettingsState();
        if (!settings) return;
        const nextVisibility = !settings.getIslandVisibility();
        const toggledFromIsland = Boolean(button.closest('#floating-island'));
        settings.setIslandVisibility(nextVisibility);
        applyIslandVisibilitySetting();

        if (!nextVisibility && toggledFromIsland) {
          const headerWrapper = document.querySelector<HTMLElement>('header .settings-cog-wrapper');
          if (!headerWrapper) return;
          document.dispatchEvent(
            new CustomEvent('takko:settings-open', {
              detail: { wrapper: headerWrapper },
            }),
          );
        }
      });
    }

    const textSizeButtons = document.querySelectorAll<HTMLElement>('[data-setting-toggle="text-size"]');
    for (const button of textSizeButtons) {
      if (button.dataset.settingBound) continue;
      button.dataset.settingBound = 'true';
      button.addEventListener('click', () => {
        const settings = getSettingsState();
        if (!settings) return;
        settings.cycleTextSize();
        applyTextSizeSetting();
      });
    }

    if (!window.__settingsCogAfterSwapBound) {
      window.__settingsCogAfterSwapBound = true;
      document.addEventListener('astro:after-swap', () => {
        initializeSettingsCogPanels();
      });
    }
  }

  if (!window.__settingsCogPageLoadBound) {
    window.__settingsCogPageLoadBound = true;
    document.addEventListener('astro:page-load', initializeSettingsCogPanels);
  }

  if (!window.__settingsCogLanguageBound) {
    window.__settingsCogLanguageBound = true;
    document.addEventListener('takko:language-changed', () => {
      applyShowDefinitionHighlightsSetting();
      applyThemeSetting();
      applyIslandVisibilitySetting();
      applyTextSizeSetting();
    });
  }

  initializeSettingsCogPanels();
</script>
