---
const { fluid = false } = Astro.props;
---

<span class:list={["translatable-text", { fluid }]}>
  <span data-lang-content="en" class="lang-en" lang="en"><slot name="en" /></span>
  <span data-lang-content="ja" class="lang-ja hidden" lang="ja"><slot name="ja" /></span>
  <span data-lang-content="en_simple" class="lang-en_simple hidden" lang="en"><slot name="en_simple" /></span>
</span>

<style is:global>
  /* Grid stacking: all 3 languages occupy same cell, container = tallest */
  .translatable-text {
    display: inline-grid;
    align-items: center;
      
    /* All children stack in same cell */
  }
  
  .translatable-text > [data-lang-content] {
    grid-row: 1;
    grid-column: 1;
    opacity: 1;
    visibility: visible;
    transition: opacity 0.15s ease-out;
  }
  
  /* Hidden: still in grid (takes up space), but invisible */
  .translatable-text > [data-lang-content].hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  
  /* Fluid mode: for inline items like nav where we DON'T want gaps */
  .translatable-text.fluid {
    display: inline;
  }
  
  .translatable-text.fluid > [data-lang-content].hidden {
    display: none;
  }
</style>