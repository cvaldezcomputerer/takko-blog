---
// src/components/T.astro
export interface Props {
  en: string;
  ja: string;
  en_simple: string;
}

const { en, ja, en_simple } = Astro.props;
---

<span class="translatable-text">
  <span data-lang-content="en" class="lang-en">{en}</span>
  <span data-lang-content="ja" class="lang-ja hidden">{ja}</span>
  <span data-lang-content="en_simple" class="lang-en_simple hidden"
    >{en_simple}</span
  >
</span>

<style is:global>
  /* Simple style to hide elements. is:global makes it available everywhere */
  .hidden {
    display: none;
  }
</style>