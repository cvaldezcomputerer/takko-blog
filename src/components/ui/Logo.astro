<style>
  .takko-logo {
    display: block;
    width: var(--logo-size, 1em);
    height: var(--logo-size, 1em);
  }

  .eye-open,
  .eye-lid {
    transition: transform 0.2s ease-in-out, opacity 0.2s ease-in-out;
    transform-box: fill-box;
    transform-origin: center;
  }

  .eye-lid {
    fill: none;
    stroke: currentColor;
    stroke-width: 14;
    stroke-linecap: round;
    opacity: 0;
    transform: scaleX(0.9);
  }

  .takko-logo:hover .eye-open {
    transform: scaleY(0);
    opacity: 0;
  }

  .takko-logo:hover .eye-lid {
    opacity: 1;
    transform: scaleX(1);
  }

  :global(a:hover) > .takko-logo .eye-open {
    transform: scaleY(0);
    opacity: 0;
  }

  :global(a:hover) > .takko-logo .eye-lid {
    opacity: 1;
    transform: scaleX(1);
  }

  :global(.is-sleeping) .eye-open {
    transform: scaleY(0);
    opacity: 0;
  }

  :global(.is-sleeping) .eye-lid {
    opacity: 1;
    transform: scaleX(1);
  }

  :global(.is-blinking) .eye-open {
    animation: takko-blink-open 520ms cubic-bezier(0.25, 0.75, 0.2, 1);
    transition: none;
  }

  :global(.is-blinking) .eye-lid {
    animation: takko-blink-lid 520ms cubic-bezier(0.25, 0.75, 0.2, 1);
    transition: none;
  }

  :global(.is-sleeping) .eye-open,
  :global(.is-sleeping) .eye-lid {
    transition: none;
  }

  @keyframes takko-blink-open {
    0% {
      transform: scaleY(1);
      opacity: 1;
    }
    45% {
      transform: scaleY(0);
      opacity: 0;
    }
    100% {
      transform: scaleY(0);
      opacity: 0;
    }
  }

  @keyframes takko-blink-lid {
    0% {
      opacity: 0;
      transform: scaleX(0.9);
    }
    45% {
      opacity: 1;
      transform: scaleX(1);
    }
    100% {
      opacity: 1;
      transform: scaleX(1);
    }
  }
</style>
