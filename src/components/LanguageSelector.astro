---
// src/components/LanguageSelector.astro
---

<div class="language-controls" aria-label="Content language">
    <button data-lang-btn="en" class="lang-btn">English</button>
    <button data-lang-btn="en_simple" class="lang-btn">Simple English</button>
    <button data-lang-btn="ja" class="lang-btn">日本語</button>
  </div>
  
  <script>
    type Language = "en" | "ja" | "en_simple";
  
    function isLanguage(value: any): value is Language {
      return ["en", "ja", "en_simple"].includes(value);
    }
  
    // This function will contain all our logic.
    function initializeLanguageSwitcher() {
      const buttons = document.querySelectorAll("[data-lang-btn]");
      const content = document.querySelectorAll("[data-lang-content]");
      const storageKey = "takko-blog-lang";
  
      // If no buttons are found on the page, do nothing.
      if (buttons.length === 0) return;
  
      function setLanguage(lang: Language) {
        content.forEach((el) => {
          const isVisible = el.getAttribute("data-lang-content") === lang;
          el.classList.toggle("hidden", !isVisible);
        });
  
        buttons.forEach((btn) => {
          const isActive = btn.getAttribute("data-lang-btn") === lang;
          btn.classList.toggle("active", isActive);
          btn.setAttribute("aria-pressed", String(isActive));
        });
  
        localStorage.setItem(storageKey, lang);
      }
  
      const savedLang = localStorage.getItem(storageKey);
      const initialLang: Language = isLanguage(savedLang) ? savedLang : "en";
      setLanguage(initialLang);
  
      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const langAttr = button.getAttribute("data-lang-btn");
          if (isLanguage(langAttr)) {
            setLanguage(langAttr);
          }
        });
      });
    }
  

    document.addEventListener("astro:page-load", initializeLanguageSwitcher);
  </script>
  
  <style>
    /* The container for the buttons */
    .language-controls {
      /* This is the key to horizontal alignment */
      display: flex;
      /* This creates space between the buttons */
      justify-content: center;
      gap: 0.75rem; /* 12px */
      /* Allows buttons to wrap on very small screens */
      flex-wrap: wrap;
      /* Adds some space below the buttons */
      margin-block: 1rem;
    }
  
    /* The default state for each button */
    .lang-btn {
      /* Remove default browser button styles */
      -webkit-appearance: none;
      -moz-appearance: none;
      appearance: none;
      
      /* Spacing and Shape */
      padding: 0.5rem 1.25rem; /* A bit more horizontal padding */
      
      
      /* Colors and Font */
      background-color: #ffffff; /* Clean white background */
      border: 1px solid #d1d5db; /* A subtle light-gray border */
      color: #374151; /* A softer, dark-gray text color */
      font-size: 0.9rem;
      font-weight: 600; /* Medium weight for readability */
      
      /* Interaction */
      cursor: pointer;
      /* Smooth transition for all changes */
      transition: all 0.2s ease-in-out;
     
      box-shadow: 0 1px 3px 0 transparent, 0 1px 2px -1px transparent;
    }
  
    /* The state when you hover over a button */
    .lang-btn:hover {
      background-color: #f3f4f6; /* A very light gray for feedback */
      border-color: #9ca3af; /* A slightly darker border on hover */
      color: #111827; /* Darken the text slightly */
    }
  
    /* The state for the currently active button */
    .lang-btn.active {
      /* A modern, friendly indigo color */
      background-color: #4f46e5;
      border-color: #4f46e5;
      color: #ffffff; /* White text for high contrast */
      font-weight: 600; /* A bit bolder to show it's selected */
      /* A subtle shadow to make it "pop" */
      box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
    }
  </style>