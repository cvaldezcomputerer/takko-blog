---
// src/components/LanguageSelector.astro
---

<div class="language-controls" aria-label="Content language">
    <button data-lang-btn="en" class="pill-button">English</button>
    <button data-lang-btn="en_simple" class="pill-button">Ez English</button>
    <button data-lang-btn="ja" class="pill-button">日本語</button>
  </div>
  
  <script>
    type Language = "en" | "ja" | "en_simple";
  
    function isLanguage(value: any): value is Language {
      return ["en", "ja", "en_simple"].includes(value);
    }
  
   
    function initializeLanguageSwitcher() {
      const buttons = document.querySelectorAll("[data-lang-btn]");
      const content = document.querySelectorAll("[data-lang-content]");
      const storageKey = "takko-blog-lang";
  
      // If no buttons are found on the page, do nothing.
      if (buttons.length === 0) return;
  
      function setLanguage(lang: Language) {
        content.forEach((el) => {
          const isVisible = el.getAttribute("data-lang-content") === lang;
          el.classList.toggle("hidden", !isVisible);
        });
  
        buttons.forEach((btn) => {
          const isActive = btn.getAttribute("data-lang-btn") === lang;
          btn.classList.toggle("active", isActive);
          btn.setAttribute("aria-pressed", String(isActive));
        });
  
        localStorage.setItem(storageKey, lang);
      }
  
      const savedLang = localStorage.getItem(storageKey);
      const initialLang: Language = isLanguage(savedLang) ? savedLang : "en";
      setLanguage(initialLang);
  
      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const langAttr = button.getAttribute("data-lang-btn");
          if (isLanguage(langAttr)) {
            setLanguage(langAttr);
          }
        });
      });
    }
  

    document.addEventListener("astro:page-load", initializeLanguageSwitcher);
  </script>
  
  <style>
    .language-controls {
      display: inline-flex;
      justify-content: center;
      gap: 0; 
      margin-block: 0;
      /* Optional: subtle shadow for the group */
      box-shadow: 0 1px 2px rgba(0,0,0,0.05);
      border-radius: 9999px;
      
      /* Track background for segmented control feel */
      background-color: rgba(0,0,0,0.02);
      padding: 0; /* Tight fit */
    }

    :global(.dark) .language-controls {
      background-color: rgba(255,255,255,0.05);
    }
  
    /* 1. Base Button Style (Inactive) */
    .pill-button {
      -webkit-appearance: none;
      appearance: none;
      background-color: transparent;
      color: rgb(var(--gray)); 
      
      /* Connected Strip Borders */
      border: 1px solid rgba(var(--gray), 0.3); 
      border-radius: 0; /* Default square */
      margin-left: -1px; /* Overlap borders */
      
      font-weight: 600;
      transition: all 0.2s ease;
      padding: 0.5rem 1.25rem; 
      font-size: 0.95rem;
      cursor: pointer;
      position: relative; 
      z-index: 1;
    }

    /* Inactive Text Colors */
    .pill-button[data-lang-btn="en"] { color: var(--pill-en); }
    .pill-button[data-lang-btn="en_simple"] { color: var(--pill-ez); }
    .pill-button[data-lang-btn="ja"] { color: var(--pill-jp); }

    /* First and Last Child Radius */
    .pill-button:first-child {
      border-top-left-radius: 9999px;
      border-bottom-left-radius: 9999px;
      margin-left: 0;
    }
    .pill-button:last-child {
      border-top-right-radius: 9999px;
      border-bottom-right-radius: 9999px;
    }

    /* 2. Hover Effect (Subtle hint) */
    .pill-button:hover {
      background-color: rgba(0,0,0,0.05);
      color: rgb(var(--black));
      z-index: 2; /* Bring border to top on hover */
    }

    /* ========================================= */
    /* 3. ACTIVE STATES */
    /* ========================================= */

    .pill-button.active {
      z-index: 10; /* Ensure active button sits on top of neighbors */
      border-color: transparent; /* Seamless active state */
    }

    /* Active: English */
    .pill-button.active[data-lang-btn="en"] {
      background-color: var(--pill-en);
      color: white;
      box-shadow: 0 2px 8px rgba(14, 165, 233, 0.3);
      border-color: var(--pill-en); 
    }

    /* Active: Ez English */
    .pill-button.active[data-lang-btn="en_simple"] {
      background-color: var(--pill-ez);
      color: white;
      box-shadow: 0 2px 8px rgba(5, 150, 105, 0.3);
      border-color: var(--pill-ez);
    }

    /* Active: Japanese */
    .pill-button.active[data-lang-btn="ja"] {
      background-color: var(--pill-jp);
      color: white;
      box-shadow: 0 2px 8px rgba(244, 63, 94, 0.3);
      border-color: var(--pill-jp);
    }

    /* Global Furigana Toggle Styles */
    :global(rt) {
      display: none;
      font-size: 0.6em;
      user-select: none;
    }
    
    :global(body.furi-active rt) {
      display: ruby-text;
    }
    
    /* Responsive adjustments */
    @media (max-width: 1100px) {
      .pill-button {
        padding: 0.35rem 1rem;
        font-size: 0.85rem;
      }
    }
    
    /* Mobile Thumb Zone */
    @media (max-width: 600px) {
      .language-controls {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 100;
        
        /* Stronger glass effect for floating UI */
        background-color: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(0,0,0,0.1);
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        
        padding: 4px; 
        gap: 0; /* Connected */
        width: auto;
        max-width: 90vw;
        flex-wrap: nowrap; /* Force single row */
      }

      :global(.dark) .language-controls {
        background-color: rgba(30, 30, 30, 0.9);
        border: 1px solid rgba(255,255,255,0.1);
      }

      .pill-button {
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        flex: 1; /* Distribute space evenly if needed, or allow auto width */
        white-space: nowrap;
      }
    }
  </style>