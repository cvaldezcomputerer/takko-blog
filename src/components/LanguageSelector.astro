---
// src/components/LanguageSelector.astro
---

<div class="language-controls" aria-label="Content language">
    <button data-lang-btn="en" class="lang-btn">English</button>
    <button data-lang-btn="en_simple" class="lang-btn">Simple English</button>
    <button data-lang-btn="ja" class="lang-btn">日本語</button>
  </div>
  
  <script>
    type Language = "en" | "ja" | "en_simple";
  
    function isLanguage(value: any): value is Language {
      return ["en", "ja", "en_simple"].includes(value);
    }
  
   
    function initializeLanguageSwitcher() {
      const buttons = document.querySelectorAll("[data-lang-btn]");
      const content = document.querySelectorAll("[data-lang-content]");
      const storageKey = "takko-blog-lang";
  
      // If no buttons are found on the page, do nothing.
      if (buttons.length === 0) return;
  
      function setLanguage(lang: Language) {
        content.forEach((el) => {
          const isVisible = el.getAttribute("data-lang-content") === lang;
          el.classList.toggle("hidden", !isVisible);
        });
  
        buttons.forEach((btn) => {
          const isActive = btn.getAttribute("data-lang-btn") === lang;
          btn.classList.toggle("active", isActive);
          btn.setAttribute("aria-pressed", String(isActive));
        });
  
        localStorage.setItem(storageKey, lang);
      }
  
      const savedLang = localStorage.getItem(storageKey);
      const initialLang: Language = isLanguage(savedLang) ? savedLang : "en";
      setLanguage(initialLang);
  
      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const langAttr = button.getAttribute("data-lang-btn");
          if (isLanguage(langAttr)) {
            setLanguage(langAttr);
          }
        });
      });
    }
  

    document.addEventListener("astro:page-load", initializeLanguageSwitcher);
  </script>
  
  <style>
    
    .language-controls {
      display: flex;
      justify-content: center;
      gap: 0.75rem; 
      flex-wrap: wrap;
      margin-block: 1rem;
    }
  
   
    .lang-btn {
      -webkit-appearance: none;
      -moz-appearance: none;
      appearance: none;
      
      padding: 0.75rem 1.5rem; 
      border-radius: 8px;
      
      background-color: #f0f9ff; 
      font-size: 0.95rem;
      font-weight: 600; 
      cursor: pointer;
      transition: all 0.3s ease-in-out;
      box-shadow: 0 2px 4px rgba(14, 165, 233, 0.1);
      position: relative;
      overflow: hidden;
    }
  
    
    .lang-btn:hover {
      background-color: #0ea5e9;
      border-color: #0284c7; 
      color: #ffffff; 
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(14, 165, 233, 0.25);
    }

    .lang-btn:active {
      transform: translateY(0);
      box-shadow: 0 2px 6px rgba(14, 165, 233, 0.2);
    }
  
    .lang-btn.active {
      background-color: #059669; 
      border-color: #059669;
      color: #ffffff; 
      font-weight: 700; 
      box-shadow: 0 4px 12px rgba(5, 150, 105, 0.3);
      transform: translateY(-1px);
    }

    .lang-btn.active:hover {
      background-color: #047857; 
      border-color: #047857;
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(5, 150, 105, 0.4);
    }

    /* Focus states for accessibility */
    .lang-btn:focus {
      outline: none;
      box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.3);
    }

    .lang-btn.active:focus {
      box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.3);
    }
    
    @media (max-width: 480px) {
      .language-controls {
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
      }
      
      .lang-btn {
        width: 100%;
        max-width: 220px;
        padding: 0.875rem 1.5rem;
        font-size: 1rem;
      }
    }
  </style>