---
---

<div class="language-controls" aria-label="Content language">
    <button data-lang-btn="en" class="pill-button">
      <span class="full-text">English</span>
      <span class="short-text">En</span>
    </button>
    <button data-lang-btn="en_simple" class="pill-button">
      <span class="full-text">Ez English</span>
      <span class="short-text">Ez</span>
    </button>
    <button data-lang-btn="ja" class="pill-button">
      <span class="full-text">日本語</span>
      <span class="short-text">日</span>
    </button>
  </div>
  
  <script>
    type Language = "en" | "ja" | "en_simple";
  
    function isLanguage(value: any): value is Language {
      return ["en", "ja", "en_simple"].includes(value);
    }
  
   
    function initializeLanguageSwitcher() {
      const buttons = document.querySelectorAll("[data-lang-btn]");
      const content = document.querySelectorAll("[data-lang-content]");
      const storageKey = "takko-blog-lang";
  
      if (buttons.length === 0) return;
  
      function setLanguage(lang: Language) {
        content.forEach((el) => {
          const isVisible = el.getAttribute("data-lang-content") === lang;
          el.classList.toggle("hidden", !isVisible);
        });
  
        buttons.forEach((btn) => {
          const isActive = btn.getAttribute("data-lang-btn") === lang;
          btn.classList.toggle("active", isActive);
          btn.setAttribute("aria-pressed", String(isActive));
        });
  
        localStorage.setItem(storageKey, lang);
      }
  
      const savedLang = localStorage.getItem(storageKey);
      const initialLang: Language = isLanguage(savedLang) ? savedLang : "en";
      setLanguage(initialLang);
  
      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const langAttr = button.getAttribute("data-lang-btn");
          if (isLanguage(langAttr)) {
            setLanguage(langAttr);
          }
        });
      });
    }
  

    document.addEventListener("astro:page-load", initializeLanguageSwitcher);
  </script>
  
  <style>
    .short-text { display: none; }

    .language-controls {
      display: inline-flex;
      justify-content: center;
      gap: 0; 
      margin-block: 0;
      box-shadow: 0 1px 2px rgba(0,0,0,0.05);
      border-radius: 9999px;
      
      background-color: rgba(0,0,0,0.02);
      padding: 0; 
    }

    :global(.dark) .language-controls {
      background-color: rgba(255,255,255,0.05);
    }
  
    .pill-button {
      -webkit-appearance: none;
      appearance: none;
      background-color: transparent;
      color: rgb(var(--gray)); 
      
      border: 1px solid rgba(var(--gray), 0.3); 
      border-radius: 0; 
      margin-left: -1px; 
      
      font-weight: 600;
      transition: all 0.2s ease;
      padding: 0.5rem 1.25rem; 
      font-size: 0.95rem;
      cursor: pointer;
      position: relative; 
      z-index: 1;
    }

    .pill-button[data-lang-btn="en"] { color: var(--pill-en); }
    .pill-button[data-lang-btn="en_simple"] { color: var(--pill-ez); }
    .pill-button[data-lang-btn="ja"] { color: var(--pill-jp); }

    .pill-button:first-child {
      border-top-left-radius: 9999px;
      border-bottom-left-radius: 9999px;
      margin-left: 0;
    }
    .pill-button:last-child {
      border-top-right-radius: 9999px;
      border-bottom-right-radius: 9999px;
    }

    .pill-button:hover {
      background-color: rgba(0,0,0,0.05);
      color: rgb(var(--black));
      z-index: 2; 
    }


    .pill-button.active {
      z-index: 10; 
      border-color: transparent; 
    }

    .pill-button.active[data-lang-btn="en"] {
      background-color: var(--pill-en);
      color: white;
      box-shadow: 0 2px 8px rgba(14, 165, 233, 0.3);
      border-color: var(--pill-en); 
    }

    .pill-button.active[data-lang-btn="en_simple"] {
      background-color: var(--pill-ez);
      color: white;
      box-shadow: 0 2px 8px rgba(5, 150, 105, 0.3);
      border-color: var(--pill-ez);
    }

    .pill-button.active[data-lang-btn="ja"] {
      background-color: var(--pill-jp);
      color: white;
      box-shadow: 0 2px 8px rgba(244, 63, 94, 0.3);
      border-color: var(--pill-jp);
    }

    :global(rt) {
      display: none;
      font-size: 0.6em;
      user-select: none;
    }
    
    :global(body.furi-active rt) {
      display: ruby-text;
    }
    
    @media (max-width: 1100px) {
      .pill-button {
        padding: 0.35rem 1rem;
        font-size: 0.85rem;
      }
    }
    
    @media (max-width: 600px) {
      .full-text { display: none; }
      .short-text { display: inline; }
      
      .pill-button {
        padding: 0.4rem 0.6rem;
        font-size: 0.8rem;
        flex: 0 0 auto; 
        white-space: nowrap;
      }
    }
  </style>