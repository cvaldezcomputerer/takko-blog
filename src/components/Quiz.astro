---
import T from './T.astro';

interface Translation {
	en: string;
	ja?: string;
	en_simple?: string;
}

interface Props {
	id: string;
	question: Translation;
	options: Translation[];
	correctAnswerIndex?: number;
}

const { id, question, options, correctAnswerIndex } = Astro.props;
---

<quiz-component data-id={id} data-correct-index={correctAnswerIndex}>
	<div class="quiz-card">
		<h3 class="quiz-question">
			<T>
				<span slot="en">{question.en}</span>
				<span slot="ja">{question.ja || question.en}</span>
				<span slot="en_simple">{question.en_simple || question.en}</span>
			</T>
		</h3>
		
		<div class="quiz-options">
			{
				options.map((option, index) => (
					<button class="quiz-option" data-index={index} type="button">
						<span class="option-label">
							<T>
								<span slot="en">{option.en}</span>
								<span slot="ja">{option.ja || option.en}</span>
								<span slot="en_simple">{option.en_simple || option.en}</span>
							</T>
						</span>
						<span class="option-percentage"></span>
						<div class="progress-bar"></div>
					</button>
				))
			}
		</div>
		
		<div class="quiz-footer">
			<span class="total-votes">Loading...</span>
		</div>
	</div>
</quiz-component>

<script>
	class QuizComponent extends HTMLElement {
		private id: string;
		private buttons: NodeListOf<HTMLButtonElement>;
		private meta: HTMLElement | null;
		private hasVoted: boolean = false;
		private currentVotes: Record<string, number> = {};
		private correctIndex: number = -1;

		constructor() {
			super();
			this.id = this.dataset.id || '';
			this.buttons = this.querySelectorAll('.quiz-option');
			this.meta = this.querySelector('.total-votes');
			this.correctIndex = this.dataset.correctIndex !== undefined ? parseInt(this.dataset.correctIndex) : -1;
		}

		connectedCallback() {
			const storedVote = localStorage.getItem(`quiz_vote_${this.id}`);
			if (storedVote) {
				this.hasVoted = true;
				this.markSelected(parseInt(storedVote));
				this.disableInteraction();
			}

			this.fetchData();

			if (!this.hasVoted) {
				this.buttons.forEach((btn) => {
					btn.addEventListener('click', (e) => this.handleVote(e));
				});
			}
		}

		async fetchData() {
			try {
				const res = await fetch(`/api/quiz/${this.id}`);
				const data = await res.json();
				this.updateUI(data);
			} catch (e) {
				console.error('Failed to load quiz data', e);
			}
		}

		async handleVote(e: Event) {
			if (this.hasVoted) return;
			
			const btn = e.currentTarget as HTMLButtonElement;
			const index = parseInt(btn.dataset.index || '0');

			this.buttons.forEach(b => b.disabled = true);

			try {
				const res = await fetch(`/api/quiz/${this.id}`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ optionIndex: index }),
				});

				if (res.ok) {
					localStorage.setItem(`quiz_vote_${this.id}`, String(index));
					this.hasVoted = true;
					this.markSelected(index);
					
					const currentCount = this.currentVotes[index] || 0;
					this.currentVotes[index] = currentCount + 1;
					this.updateUI(this.currentVotes);
					this.disableInteraction();
				}
			} catch (err) {
				console.error('Vote failed', err);
				this.buttons.forEach(b => b.disabled = false); 
			}
		}

		markSelected(index: number) {
			const btn = this.querySelector(`.quiz-option[data-index="${index}"]`);
			if(btn) btn.classList.add('selected');
		}

		disableInteraction() {
			this.buttons.forEach(btn => {
				btn.disabled = true;
				btn.classList.add('show-results');

				if (this.correctIndex !== -1 && !isNaN(this.correctIndex)) {
					const btnIndex = parseInt(btn.dataset.index || '-1');
					
					if (btnIndex === this.correctIndex) {
						btn.classList.add('correct');
					}
					else if (btn.classList.contains('selected')) {
						btn.classList.add('wrong');
					}
				}
			});
		}

		updateUI(votesObj: Record<string, number>) {
			let total = 0;
			this.currentVotes = votesObj; 
			const counts: Record<string, number> = {};
			
			this.buttons.forEach(btn => {
				const idx = btn.dataset.index || '0';
				const count = votesObj[idx] || 0;
				counts[idx] = count;
				total += count;
			});

			if (this.meta) this.meta.textContent = `${total} votes`;

			this.buttons.forEach(btn => {
				const idx = btn.dataset.index || '0';
				const count = counts[idx];
				const percent = total === 0 ? 0 : Math.round((count / total) * 100);
				
				const bar = btn.querySelector('.progress-bar') as HTMLElement;
				if(bar) bar.style.width = this.hasVoted ? `${percent}%` : '0%';

				const text = btn.querySelector('.option-percentage');
				if(text) text.textContent = this.hasVoted ? `${percent}%` : '';
			});
		}
	}

	if (!customElements.get('quiz-component')) {
		customElements.define('quiz-component', QuizComponent);
	}
</script>

<style>
	.quiz-card {
		background: #fff;
		border: 2px solid #eee;
		border-radius: 12px;
		padding: 1.5rem;
		margin: 2rem 0;
		box-shadow: 0 4px 6px rgba(0,0,0,0.02);
		transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;
	}
	:global(.dark) .quiz-card {
		background: var(--secondary);
		border-color: var(--highlight);
		color: var(--text);
	}
	.quiz-question {
		margin-top: 0;
		margin-bottom: 1rem;
		font-size: 1.2rem;
		font-weight: 700;
		color: inherit;
	}
	.quiz-options {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.quiz-option {
		position: relative;
		display: flex;
		justify-content: space-between;
		align-items: center;
		width: 100%;
		padding: 0.75rem 1rem;
		background: #f9fafb;
		border: 2px solid transparent;
		border-radius: 8px;
		cursor: pointer;
		font-family: inherit;
		font-size: 1rem;
		color: #333;
		overflow: hidden; 
		transition: all 0.2s ease;
		z-index: 1;
	}
	:global(.dark) .quiz-option {
		background: var(--background);
		color: var(--text);
		border-color: transparent;
	}
	
	.quiz-option:not(:disabled):hover {
		background: #f3f4f6;
		border-color: #d1d5db;
	}
	:global(.dark) .quiz-option:not(:disabled):hover {
		background: var(--highlight);
		border-color: var(--gray);
	}
	
	.quiz-option:focus {
		outline: none;
	}
	
	.quiz-option:focus-visible {
		border-color: var(--accent);
		box-shadow: 0 0 0 2px rgba(var(--gray), 0.2);
	}

	.quiz-option.selected {
		border-color: var(--accent);
		font-weight: 600;
	}

	.quiz-option.correct {
		border-color: #22c55e;
		background-color: #f0fdf4;
	}
	:global(.dark) .quiz-option.correct {
		background-color: rgba(34, 197, 94, 0.2);
		border-color: #22c55e;
	}
	.quiz-option.correct .progress-bar {
		background-color: #22c55e;
		opacity: 0.2;
	}
	.quiz-option.correct .option-percentage {
		color: #15803d;
	}

	.quiz-option.wrong {
		border-color: #ef4444;
		background-color: #fef2f2;
	}
	:global(.dark) .quiz-option.wrong {
		background-color: rgba(239, 68, 68, 0.2);
		border-color: #ef4444;
	}
	.quiz-option.wrong .progress-bar {
		background-color: #ef4444;
		opacity: 0.2;
	}
	.quiz-option.wrong .option-percentage {
		color: #b91c1c;
	}

	.progress-bar {
		position: absolute;
		top: 0;
		left: 0;
		height: 100%;
		background-color: var(--accent);
		opacity: 0.15;
		width: 0%;
		z-index: -1;
		transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
	}
	
	.quiz-option.selected .progress-bar {
		opacity: 0.25;
	}

	.option-label {
		z-index: 2;
	}
	.option-percentage {
		z-index: 2;
		font-weight: bold;
		color: var(--accent);
	}

	.quiz-footer {
		margin-top: 1rem;
		font-size: 0.85rem;
		color: rgb(var(--gray));
		text-align: right;
	}
</style>