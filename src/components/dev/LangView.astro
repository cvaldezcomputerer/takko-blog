---
// Renders the three language variants of a translatable block for the dev
// editor. Presentational only; no Node/browser dependencies.
/** @typedef {{ en?: string, ja?: string, en_simple?: string }} Slots */
const { slots } = Astro.props;
/** @type {[keyof Slots, string][]} */
const rows = [
  ["en", "en"],
  ["ja", "ja"],
  ["en_simple", "simple"],
];
---

<div class="langs">
  {
    rows.map(([key, label]) => (
      <div class={`lang ${key}`}>
        <span class="k">{label}</span>
        {slots[key]
          ? <span class="v">{slots[key]}</span>
          : <span class="v missing">(none)</span>}
      </div>
    ))
  }
</div>
