---
const { images = [] } = Astro.props;
---
<div class="scrapbook-container">
  {images.length > 0 ? (
    images.map((img) => (
      <div class="photo-card">
        <img src={img} loading="lazy" decoding="async" alt="" />
      </div>
    ))
  ) : (
    <slot />
  )}
</div>

<style>
  /* 
   * NEW SCRAPBOOK STYLES 
   */
  .scrapbook-container {
    /* 1. The Paper Color & Grid Background */
    background-color: var(--secondary);
    color: #333;
    
    /* Creates a grid pattern */
    background-image: 
      linear-gradient(#e1e1e1 1px, transparent 1px),
      linear-gradient(90deg, #e1e1e1 1px, transparent 1px);
    background-size: 20px 20px; /* Size of the grid squares */
    
    /* Structure & Spacing */
    position: relative; /* Essential for the tape positioning */
    padding: 40px 20px 60px 20px; /* Reduced side padding to help fit 3 cards */
    margin: 50px auto;
    border: 1px solid #ddd;
    
    /* Make it look like a stack of paper */
    box-shadow: 
      5px 5px 0px #f0f0f0,
      10px 10px 0px #e0e0e0;
      
    max-width: 100%; /* Ensure it doesn't overflow parent */
    
    /* Flexbox for Polaroids */
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
  }

  :global(.dark) .scrapbook-container {
    background-color: var(--secondary);
    background-image: 
      linear-gradient(rgba(var(--gray), 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(var(--gray), 0.1) 1px, transparent 1px);
    border-color: rgba(var(--gray), 0.2);
    box-shadow: 
      5px 5px 0px rgba(var(--gray), 0.1),
      10px 10px 0px rgba(var(--gray), 0.05);
    color: var(--text);
  }

  /* 3. The Tape */
  .scrapbook-container::before {
    content: "";
    position: absolute;
    top: -15px; /* Pulls tape slightly above the container */
    left: 50%;
    transform: translateX(-50%) rotate(-1.5deg); /* Centers and tilts it */
    
    width: 140px;
    height: 35px;
    
    /* Tape Styling */
    background-color: rgba(230, 230, 230, 0.5); /* Semi-transparent */
    border-left: 2px dashed rgba(0,0,0,0.1);  /* Ragged edges */
    border-right: 2px dashed rgba(0,0,0,0.1);
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    backdrop-filter: blur(2px); /* Makes it look like matte tape */
    z-index: 10; /* Ensure tape is on top */
  }

  :global(.dark) .scrapbook-container::before {
    background-color: rgba(240, 230, 140, 0.15);
  }

  /* 
   * EXISTING POLAROID STYLES (Adapted)
   */
  
  .photo-card,
  .scrapbook-container :global(figure) {
    background: white;
    /* Polaroid Spacing: Equal top/sides, large bottom */
    padding: 12px 12px 50px 12px; 
    box-shadow: 2px 4px 12px rgba(0,0,0,0.2);
    width: 180px; /* Reduced width to fit 3 per row more easily */
    height: 240px; /* Fixed height to prevent layout shift on hover */
    display: flex;
    flex-direction: column;
    align-items: center;
    
    transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1), background 0.5s, box-shadow 0.5s;
    z-index: 1;
    cursor: pointer;
    border: 1px solid rgba(0,0,0,0.05);
    position: relative; 

    will-change: transform;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    outline: 1px solid transparent;
  }

  :global(.dark) .photo-card,
  :global(.dark) .scrapbook-container :global(figure) {
    background: var(--text);
  }
  
  /* Reset default figure margin */
  .scrapbook-container :global(figure) {
    margin: 0;
  }

  .photo-card img,
  .scrapbook-container :global(figure img) {
    width: 100%;
    aspect-ratio: 1 / 1; 
    object-fit: cover;
    display: block;
    border: 2px solid rgba(255,255,255,0);
    transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.5s, border 0.5s;
    border-radius: 0;

    will-change: transform;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
  }
  
  .scrapbook-container :global(figcaption) {
     position: absolute;
     bottom: 10px;
     left: 10px;
     right: 10px;
     text-align: center;
     font-family: "Courier New", Courier, monospace;
     font-size: 0.8em;
     color: #444;
     margin-top: 0;
     line-height: 1.2;
     max-height: 40px;
     overflow: hidden;
     transition: opacity 0.4s;
  }

  :global(.dark) .scrapbook-container :global(figcaption) {
    color: var(--background);
  }

  /* Randomness */
  .photo-card:nth-child(odd),
  .scrapbook-container :global(figure:nth-child(odd)) { transform: rotate(-3deg) translateZ(0); }
  
  .photo-card:nth-child(even),
  .scrapbook-container :global(figure:nth-child(even)) { transform: rotate(2deg) translateZ(0); margin-top: 20px; }
  
  .photo-card:nth-child(3n),
  .scrapbook-container :global(figure:nth-child(3n)) { transform: rotate(4deg) translateZ(0); margin-top: -10px; }
  
  .photo-card:nth-child(5n),
  .scrapbook-container :global(figure:nth-child(5n)) { transform: rotate(-5deg) translateZ(0); margin-top: 10px; }

  @media (max-width: 600px) {
    .scrapbook-container {
      gap: 0;
      padding: 20px 10px;
    }
    
    .photo-card,
    .scrapbook-container :global(figure) {
      margin-bottom: -120px; 
      /* Ensure width resets */
      width: 200px;
    }
    
    .photo-card:last-child,
    .scrapbook-container :global(figure:last-child) {
      margin-bottom: 0;
    }
    
    .photo-card:nth-child(n), .scrapbook-container :global(figure:nth-child(n)) { margin-top: 0; }
  }

  /* Hover Effects (Global - defaults to desktop behavior) */
  .photo-card:hover,
  .scrapbook-container :global(figure:hover) {
    transform: rotate(0deg) translateZ(0);
    z-index: 1000;
    background: transparent;
    box-shadow: none;
    border-color: transparent;
  }
  
  .photo-card:hover :global(figcaption),
  .scrapbook-container :global(figure:hover figcaption) {
    opacity: 0;
  }

  .photo-card:hover img,
  .scrapbook-container :global(figure:hover img) {
    position: absolute;
    width: auto;
    height: auto;
    max-width: 400px;
    max-height: 60vh;
    aspect-ratio: unset;
    object-fit: contain;
    
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(1.1);
    
    box-shadow: 0 15px 40px rgba(0,0,0,0.4);
    border-radius: 0;
    border: 2px solid white;
    background: white; 
  }

  /* Mobile Hover/Focus Override: Keep Polaroid look, just zoom and show caption */
  @media (max-width: 600px) {
    .photo-card:hover,
    .scrapbook-container :global(figure:hover) {
      background: white;
      box-shadow: 0 10px 25px rgba(0,0,0,0.3);
      transform: scale(1.02) rotate(0deg) translateZ(0);
      border: 1px solid rgba(0,0,0,0.05);
      
      width: 90vw;
      max-width: none;
      
      height: auto;
      
      /* Half border (6px) top/sides, space for caption bottom */
      padding: 6px 6px 10px 6px;
      z-index: 1000;
    }

    .photo-card:hover img,
    .scrapbook-container :global(figure:hover img) {
      /* Reset "pop-out" styles */
      position: static;
      width: 100%;
      height: auto;
      max-width: none;
      max-height: none;
      transform: none;
      box-shadow: none;
      border: 1px solid rgba(0,0,0,0.1);
      top: auto;
      left: auto;
      border-radius: 0;
    }

    .photo-card:hover :global(figcaption),
    .scrapbook-container :global(figure:hover figcaption) {
      opacity: 1;
      position: static; /* Flow in flex container */
      width: 100%;
      margin-top: 10px;
      max-height: none;
      overflow: visible;
      white-space: normal;
      padding: 0 10px;
    }
  }
</style>