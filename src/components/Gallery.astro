---
const { images = [] } = Astro.props;
---
<div class="extras-container">
  <div class="scatter-container">
    {images.length > 0 ? (
      images.map((img) => (
        <div class="photo-card">
          <img src={img} loading="lazy" decoding="async" alt="" />
        </div>
      ))
    ) : (
      <slot />
    )}
  </div>
</div>

<style>
  .extras-container { margin: 1rem 0; }

  .scatter-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    
    padding: 50px 20px;
    background: transparent;
    margin-top: 0;
    position: relative;
  }
  
  .photo-card,
  .scatter-container :global(figure) {
    background: white;
    /* Polaroid Spacing: Equal top/sides, large bottom */
    padding: 12px 12px 50px 12px; 
    box-shadow: 2px 4px 12px rgba(0,0,0,0.2);
    width: 200px;
    height: 240px; /* Fixed height to prevent layout shift on hover */
    display: flex;
    flex-direction: column;
    align-items: center;
    
    transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1), background 0.5s, box-shadow 0.5s;
    z-index: 1;
    cursor: pointer;
    border: 1px solid rgba(0,0,0,0.05);
    position: relative; /* Anchor for absolute hover image */

    /* Fix for anti-aliasing/jitter on animation end */
    will-change: transform;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    outline: 1px solid transparent; /* Hack to improve anti-aliasing on rotated edges */
  }
  
  /* Reset default figure margin */
  .scatter-container :global(figure) {
    margin: 0;
  }

  .photo-card img,
  .scatter-container :global(figure img) {
    width: 100%;
    /* Square aspect ratio is classic Polaroid */
    aspect-ratio: 1 / 1; 
    object-fit: cover;
    display: block;
    border: 2px solid rgba(255,255,255,0);
    /* Slower animation - Targeted properties to avoid layout snap */
    transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.5s, border 0.5s;
    border-radius: 0;

    /* Fix for anti-aliasing/jitter on animation end */
    will-change: transform;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
  }
  
  .scatter-container :global(figcaption) {
     position: absolute;
     bottom: 10px;
     left: 10px;
     right: 10px;
     text-align: center;
     font-family: "Courier New", Courier, monospace;
     font-size: 0.8em;
     color: #444;
     margin-top: 0;
     line-height: 1.2;
     max-height: 40px;
     overflow: hidden;
     transition: opacity 0.4s;
  }

  /* CSS Tricks for "Randomness" */
  .photo-card:nth-child(odd),
  .scatter-container :global(figure:nth-child(odd)) { transform: rotate(-3deg) translateZ(0); }
  
  .photo-card:nth-child(even),
  .scatter-container :global(figure:nth-child(even)) { transform: rotate(2deg) translateZ(0); margin-top: 20px; }
  
  .photo-card:nth-child(3n),
  .scatter-container :global(figure:nth-child(3n)) { transform: rotate(4deg) translateZ(0); margin-top: -10px; }
  
  .photo-card:nth-child(5n),
  .scatter-container :global(figure:nth-child(5n)) { transform: rotate(-5deg) translateZ(0); margin-top: 10px; }

  @media (max-width: 600px) {
    .scatter-container {
      gap: 0;
      padding: 20px 10px;
    }
    
    .photo-card,
    .scatter-container :global(figure) {
      /* Overlap vertically slightly for a "stack" feel */
      margin-bottom: -120px; 
    }
    
    .photo-card:last-child,
    .scatter-container :global(figure:last-child) {
      margin-bottom: 0;
    }
    
    /* Reset the random margin-top offsets for the stacked mobile view */
    .photo-card:nth-child(n), .scatter-container :global(figure:nth-child(n)) { margin-top: 0; }
  }

  /* Interaction: "Break off" the frame and show full image */
  .photo-card:hover,
  .scatter-container :global(figure:hover) {
    transform: rotate(0deg) translateZ(0);
    z-index: 1000;
    background: transparent;
    box-shadow: none;
    border-color: transparent;
  }
  
  .photo-card:hover :global(figcaption),
  .scatter-container :global(figure:hover figcaption) {
    opacity: 0;
  }

  .photo-card:hover img,
  .scatter-container :global(figure:hover img) {
    position: absolute;
    width: auto;
    height: auto;
    max-width: 400px;
    max-height: 60vh;
    aspect-ratio: unset;
    object-fit: contain;
    
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(1.1);
    
    box-shadow: 0 15px 40px rgba(0,0,0,0.4);
    border-radius: 0;
    border: 2px solid white;
    background: white; /* Ensure background behind transparent image parts if any */
  }
  
  @media (max-width: 600px) {
    .photo-card:hover img,
    .scatter-container :global(figure:hover img) {
      max-width: 90vw;
      max-height: 50vh;
    }
  }

  /* Mobile Hover/Focus Override: Keep Polaroid look, just zoom and show caption */
  @media (max-width: 600px) {
    .photo-card:hover,
    .scatter-container :global(figure:hover) {
      background: white;
      box-shadow: 0 10px 25px rgba(0,0,0,0.3);
      transform: scale(1.02) rotate(0deg) translateZ(0);
      border: 1px solid rgba(0,0,0,0.05);
      
      width: 90vw;
      max-width: none;
      
      height: auto;
      
      /* Half border (6px) top/sides, space for caption bottom */
      padding: 6px 6px 10px 6px;
    }

    .photo-card:hover img,
    .scatter-container :global(figure:hover img) {
      /* Reset "pop-out" styles */
      position: static;
      width: 100%;
      height: auto;
      max-width: none;
      max-height: none;
      transform: none;
      box-shadow: none;
      border: 1px solid rgba(0,0,0,0.1);
      top: auto;
      left: auto;
      border-radius: 0;
    }

    .photo-card:hover :global(figcaption),
    .scatter-container :global(figure:hover figcaption) {
      opacity: 1;
      position: static; /* Flow in flex container */
      width: 100%;
      margin-top: 10px;
      max-height: none;
      overflow: visible;
      white-space: normal;
      padding: 0 10px;
    }
  }
</style>