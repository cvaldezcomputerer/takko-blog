---
const { images = [] } = Astro.props;
---
<div class="extras-container">
  <!-- Title removed as per user request -->
  <div class="scatter-container">
    {images.length > 0 ? (
      images.map((img) => (
        <div class="photo-card">
          <img src={img} loading="lazy" decoding="async" alt="" />
        </div>
      ))
    ) : (
      <slot />
    )}
  </div>
</div>

<style>
  .extras-container { margin: 1rem 0; /* Reduced from 3rem */ }

  .scatter-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    
    padding: 50px 20px;
    background: transparent; 
    margin-top: 0; /* Removed top margin */
    position: relative;
  }
  
  .photo-card,
  .scatter-container :global(figure) {
    background: white;
    /* Polaroid Spacing: Equal top/sides, large bottom */
    padding: 12px 12px 50px 12px; 
    box-shadow: 2px 4px 12px rgba(0,0,0,0.2);
    width: 200px;
    height: 240px; /* Fixed height to prevent layout shift on hover */
    display: flex;
    flex-direction: column;
    align-items: center;
    
    /* Slower animation */
    transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1), background 0.5s, box-shadow 0.5s;
    z-index: 1;
    cursor: pointer;
    /* Subtle border for the card itself */
    border: 1px solid rgba(0,0,0,0.05); 
    position: relative; /* Anchor for absolute hover image */
  }
  
  /* Reset default figure margin */
  .scatter-container :global(figure) {
    margin: 0;
  }

  .photo-card img,
  .scatter-container :global(figure img) {
    width: 100%;
    /* Square aspect ratio is classic Polaroid */
    aspect-ratio: 1 / 1; 
    object-fit: cover;
    display: block;
    /* Slight inner shadow or border to define image edge against white */
    border: 1px solid rgba(0,0,0,0.1); 
    /* Slower animation - Targeted properties to avoid layout snap */
    transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.5s, border 0.5s;
  }
  
  /* Caption styling */
  .scatter-container :global(figcaption) {
     position: absolute;
     bottom: 10px;
     left: 10px;
     right: 10px;
     text-align: center;
     font-family: "Courier New", Courier, monospace;
     font-size: 0.8em;
     color: #444;
     margin-top: 0;
     line-height: 1.2;
     max-height: 40px;
     overflow: hidden;
     transition: opacity 0.4s;
  }

  /* CSS Tricks for "Randomness" */
  .photo-card:nth-child(odd),
  .scatter-container :global(figure:nth-child(odd)) { transform: rotate(-3deg); }
  
  .photo-card:nth-child(even),
  .scatter-container :global(figure:nth-child(even)) { transform: rotate(2deg); margin-top: 20px; }
  
  .photo-card:nth-child(3n),
  .scatter-container :global(figure:nth-child(3n)) { transform: rotate(4deg); margin-top: -10px; }
  
  .photo-card:nth-child(5n),
  .scatter-container :global(figure:nth-child(5n)) { transform: rotate(-5deg); margin-top: 10px; }

  /* Mobile Adjustments */
  @media (max-width: 600px) {
    .scatter-container {
      gap: 0; /* Remove horizontal/vertical gap */
      padding: 20px 10px; /* Less padding around container */
    }
    
    .photo-card,
    .scatter-container :global(figure) {
      /* Overlap vertically slightly for a "stack" feel */
      margin-bottom: -120px; 
      /* Make sure last one doesn't overlap nothing */
    }
    
    .photo-card:last-child,
    .scatter-container :global(figure:last-child) {
      margin-bottom: 0;
    }
    
    /* Reduce random margins on mobile so the stack is straighter/cleaner? 
       Or keep the chaos? "Stack them up" implies overlap. 
       Let's keep rotation but reset margin-top offsets so the overlap is consistent.
    */
    .photo-card:nth-child(even),
    .scatter-container :global(figure:nth-child(even)) { margin-top: 0; }
    
    .photo-card:nth-child(3n),
    .scatter-container :global(figure:nth-child(3n)) { margin-top: 0; }
    
    .photo-card:nth-child(5n),
    .scatter-container :global(figure:nth-child(5n)) { margin-top: 0; }
  }

  /* Interaction: "Break off" the frame and show full image */
  .photo-card:hover,
  .scatter-container :global(figure:hover) {
    transform: rotate(0deg); /* Straighten up */
    z-index: 1000; /* Ensure it's on top of everything */
    background: transparent; /* Hide polaroid paper */
    box-shadow: none; /* Remove paper shadow */
    border-color: transparent;
    /* On mobile, if we overlap, we need to cancel the negative margin on hover? 
       Actually, z-index 1000 and absolute positioning of the child img handles the visual.
       The card itself stays in flow. 
    */
  }
  
  /* Reset margin on hover for mobile to prevent jumping? 
     Actually, changing margin on hover causes layout shift. 
     Better to not change margin on hover. 
  */
  @media (max-width: 600px) {
    .photo-card:hover,
    .scatter-container :global(figure:hover) {
       margin-bottom: -120px; /* Keep the overlap */
    }
  }
  
  /* Hide caption on hover */
  .photo-card:hover :global(figcaption),
  .scatter-container :global(figure:hover figcaption) {
    opacity: 0;
  }

  /* Transform the image */
  .photo-card:hover img,
  .scatter-container :global(figure:hover img) {
    position: absolute;
    width: auto;
    height: auto;
    max-width: 400px; /* Limit size */
    max-height: 60vh;
    aspect-ratio: unset; /* Show full shape */
    object-fit: contain;
    
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(1.1); /* Center and slight scale */
    
    box-shadow: 0 15px 40px rgba(0,0,0,0.4); /* Strong shadow for the photo itself */
    border-radius: 4px;
    border: 2px solid white; /* Optional: Nice photo border */
    background: white; /* Ensure background behind transparent image parts if any */
  }
  
  /* Mobile hover adjustment: Image shouldn't be too big */
  @media (max-width: 600px) {
    .photo-card:hover img,
    .scatter-container :global(figure:hover img) {
      max-width: 90vw;
      max-height: 50vh;
    }
  }

  /* Mobile Hover/Focus Override: Keep Polaroid look, just zoom and show caption */
  @media (max-width: 600px) {
    .photo-card:hover,
    .scatter-container :global(figure:hover) {
      background: white; /* Keep background */
      box-shadow: 0 10px 25px rgba(0,0,0,0.3); /* Restore shadow */
      transform: scale(1.02) rotate(0deg); /* Slight zoom, straighten */
      border: 1px solid rgba(0,0,0,0.05); /* Restore border */
      
      /* Expand width to fill screen */
      width: 90vw;
      max-width: none;
      
      /* Allow height to grow for caption */
      height: auto;
      
      /* Half border (6px) top/sides, space for caption bottom */
      padding: 6px 6px 10px 6px;
    }

    .photo-card:hover img,
    .scatter-container :global(figure:hover img) {
      /* Reset "pop-out" styles */
      position: static;
      width: 100%;
      height: auto;
      max-width: none;
      max-height: none;
      transform: none;
      box-shadow: none;
      border: 1px solid rgba(0,0,0,0.1); /* Keep inner border */
      top: auto;
      left: auto;
      border-radius: 0;
    }

    .photo-card:hover :global(figcaption),
    .scatter-container :global(figure:hover figcaption) {
      /* Show and position caption below image */
      opacity: 1;
      position: static; /* Flow in flex container */
      width: 100%;
      margin-top: 10px;
      max-height: none; /* Show full text */
      overflow: visible;
      white-space: normal;
      padding: 0 10px; /* Add breathing room for text */
    }
  }
</style>