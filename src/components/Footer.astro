---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} Cristian Valdez. All rights reserved.
	<div class="social-links">
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: var(--accent);
		color: #fff;
		text-align: center;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: #fff;
	}
	.social-links a:hover {
		color: var(--highlight);
	}
</style>
