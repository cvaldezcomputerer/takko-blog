---
import Logo from './Logo.astro';
import { SITE_TITLE } from '../consts';

const today = new Date();
---

<footer class="site-footer">
	<div class="footer-content">
		<div class="footer-brand">
			<Logo class="footer-logo" style="--logo-size: 46px;" />
			<span class="site-title">{SITE_TITLE}</span>
		</div>

		<div class="footer-middle">
			<nav class="footer-nav">
				<a href="/">Home</a>
				<a href="/about">About</a>
				<a href="/contact/">Contact</a>
			</nav>

			<div class="footer-separator" aria-hidden="true"></div>

			<div class="social-icons">
				<a href="/rss.xml" aria-label="RSS Feed" title="RSS Feed">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
				</a>
				<a href="https://www.linkedin.com/in/cristian-valdez-203136378" target="_blank" aria-label="Follow me on LinkedIn" title="LinkedIn">
					<svg viewBox="0 0 16 16" aria-hidden="true" width="28" height="28" fill="currentColor">
						<path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/>
					</svg>
				</a>
				<a href="https://github.com/cvaldezcomputerer" target="_blank" aria-label="Go to Cristian's GitHub repo" title="GitHub">
					<svg viewBox="0 0 16 16" aria-hidden="true" width="28" height="28" fill="currentColor">
						<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
					</svg>
				</a>
			</div>
		</div>

		<div class="copyright">
			&copy; {today.getFullYear()} Cristian Valdez. All rights reserved.
		</div>
	</div>
</footer>

<style>
	footer {
		background-color: var(--secondary);
		color: var(--text);
		margin-top: auto;
		padding: 3rem 1.5rem;
		border-top: 1px solid rgb(var(--gray-light));
	}

	.footer-content {
		max-width: 900px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 2rem;
		width: 100%; 
	}

	.footer-brand {
		display: flex;
		align-items: center;
		justify-content: center; 
		gap: 0.75rem;
		font-weight: bold;
		font-size: 1.2em;
		color: inherit;
	}
	.footer-logo {
		color: inherit;
	}

	.footer-middle {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
		width: 100%;
	}
	
	@media (min-width: 600px) {
		.footer-middle {
			flex-direction: row;
			gap: 2rem;
		}
	}

	.footer-nav {
		display: flex;
		gap: 1.5rem;
		align-items: center;
	}

	.footer-nav a {
		text-decoration: none;
		color: inherit; 
		font-weight: 500;
		opacity: 0.8;
		transition: all 0.2s ease;
	}

	.footer-nav a:hover {
		opacity: 1;
		color: var(--accent);
	}

	.footer-separator {
		display: none;
	}
	@media (min-width: 600px) {
		.footer-separator {
			display: block;
			width: 1px;
			height: 24px;
			background-color: currentColor;
			opacity: 0.2;
		}
	}

	.social-icons {
		display: flex;
		gap: 1rem;
		align-items: center;
		justify-content: center;
	}

	.social-icons a {
		color: inherit; 
		opacity: 0.7;
		transition: all 0.2s ease;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 4px; 
	}

	.social-icons a:hover {
		opacity: 1;
		color: var(--accent);
		transform: translateY(-2px);
	}

	.copyright {
		font-size: 0.85em;
		opacity: 0.6;
		margin-top: 0.5rem;
	}
</style>
