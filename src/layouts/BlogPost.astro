---
import BaseHead from '../components/layout/BaseHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import FormattedDate from '../components/content/FormattedDate.astro';
import LikeButton from '../components/content/LikeButton.astro';
import OptimizedImage from '../components/media/OptimizedImage.astro';
import T from '../components/i18n/T.astro';
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'] & { slug: string };

const {
	title,
	title_ja,
	title_en_simple,
	description,
	pubDate,
	updatedDate,
	heroImage,
	slug,
	heroImageFit,
	cameraUsedName,
	cameraUsedImage,
	cameraUsedImageAlt,
	cameraUsedLink,
	cameraUsedLinkLabel,
} = Astro.props as Props;

function isOptimizedImageSrc(value: unknown): value is ImageMetadata | string {
	if (typeof value === 'string') return true;
	if (!value || typeof value !== 'object') return false;
	const maybeImage = value as Partial<ImageMetadata>;
	return typeof maybeImage.src === 'string';
}
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script is:inline>
			const hue = Math.floor(Math.random() * 360);
			document.documentElement.style.setProperty('--theme-hue', hue.toString());
		</script>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0 auto;
			}
			.hero-image {
				width: 100%;
				max-width: 1080px;
				margin: 0 auto 2rem auto;
			}
			.hero-image :global(img) {
				display: block;
				margin: 0 auto;
				border-radius: var(--radius-md);
				box-shadow: var(--box-shadow);
				max-height: 510px;  
    			object-fit: cover;  
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 0.5em;
				padding: 0.5em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.25em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.post-meta-line {
				margin-top: 0.6rem;
				display: flex;
				justify-content: center;
			}
			.camera-used {
				display: inline-flex;
				align-items: center;
				gap: 0.7rem;
				padding: 0.6rem 0.9rem;
				border-radius: 14px;
				background: rgba(var(--gray-light), 0.5);
				border: 1px solid rgba(var(--gray), 0.18);
				color: rgb(var(--gray-dark));
				font-size: 1rem;
				line-height: 1.1;
				text-align: left;
				max-width: min(100%, 680px);
			}
			.camera-used__thumb {
				width: 46px;
				height: 46px;
				object-fit: cover;
				border-radius: var(--radius-md);
				flex-shrink: 0;
				background: rgba(255, 255, 255, 0.75);
				border: 1px solid rgba(var(--gray), 0.18);
			}
			.camera-used__label {
				font-weight: 700;
				color: rgb(var(--gray));
				margin-right: 0.15rem;
			}
			.camera-used__name {
				font-weight: 700;
				color: rgb(var(--gray-dark));
			}
			.camera-used__link {
				color: inherit;
				text-decoration: none;
			}
			.camera-used__link:hover .camera-used__name {
				text-decoration: underline;
			}
			@media (max-width: 640px) {
				.camera-used {
					border-radius: var(--radius-md);
					padding: 0.65rem 0.75rem;
					align-items: flex-start;
				}
				.camera-used__copy {
					display: inline-block;
				}
			}
			.last-updated-on {
				font-style: italic;
			}
			.prose :global(figure) {
				margin: 1.8em 0 1.3em 0;
			}
			.prose :global(figure img) {
				display: block;
				margin: 0 auto;
				border-radius: var(--radius-md);
				box-shadow: var(--box-shadow);
				max-height: 600px;
				width: auto;
			}
			.prose :global(figcaption) {
				margin-top: 0.75em;
				font-size: 0.875em ;
				color: rgb(var(--gray)) ;
				text-align: center;
				font-style: italic;
				font-weight: 700 ;
				line-height: 1.5;
			}
			.prose :global(figcaption a) {
				white-space: nowrap;
			}
			.prose :global(.scrapbook-container figure) {
				margin: 0;
			}
			.prose :global(.scrapbook-container figure img) {
				border-radius: 0;
				box-shadow: none;
				max-height: none;
				width: 100%;
			}
			.prose :global(.scrapbook-container figure:hover img) {
				width: auto;
				max-height: 60vh;
				box-shadow: 0 15px 40px rgba(0,0,0,0.4);
			}
			.prose[data-blog-content] :global(img:not([data-lightbox="off"])) {
				cursor: zoom-in;
			}
			.lightbox-dialog {
				border: 0;
				padding: 0;
				margin: auto;
				max-width: min(88vw, 1000px);
				max-height: 88vh;
				background: transparent;
			}
			.lightbox-dialog::backdrop {
				background: rgba(0, 0, 0, 0.75);
				backdrop-filter: blur(2px);
			}
			.lightbox-content {
				position: relative;
				background: rgb(var(--gray-dark));
				border-radius: var(--radius-md);
				padding: 1rem;
			}
			.lightbox-dialog img {
				display: block;
				max-width: min(80vw, 900px);
				max-height: 68vh;
				width: auto;
				height: auto;
				border-radius: var(--radius);
				box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
			}
			.lightbox-close {
				position: absolute;
				top: 0.5rem;
				right: 0.5rem;
				width: 2.25rem;
				height: 2.25rem;
				border: 1px solid rgba(0, 0, 0, 0.1);
				border-radius: var(--radius-pill);
				background: rgba(255, 255, 255, 0.96);
				color: #222;
				font-size: 1.15rem;
				line-height: 2.2rem;
				text-align: center;
				cursor: pointer;
				box-shadow: 0 4px 14px rgba(0, 0, 0, 0.2);
				transition: background-color 120ms ease, transform 120ms ease;
			}
			.lightbox-close:hover {
				background: #fff;
				transform: scale(1.04);
			}
			.post-outro {
				margin-top: 2.25rem;
				padding: 0.95rem 0.95rem 0.85rem;
				border-radius: var(--radius-lg);
				border: 1px solid rgba(var(--gray), 0.18);
				border-top: 2px solid rgba(var(--accent), 0.5);
				background: rgba(var(--gray-light), 0.28);
				text-align: center;
				box-shadow: 0 4px 14px rgba(0, 0, 0, 0.04);
			}
			.post-outro__title {
				margin: 0 0 0.45rem 0;
				font-size: 1.15rem;
				font-weight: 800;
				line-height: 1.1;
				color: rgb(var(--gray-dark));
			}
			.post-outro__line {
				margin: 0;
				line-height: 1.5;
				color: rgb(var(--gray-dark));
			}
			.post-outro__line + .post-outro__line {
				margin-top: 0.5rem;
			}
			.post-outro__link {
				display: inline;
				margin: 0 0.18rem;
				padding: 0;
				background: transparent;
				color: var(--accent);
				font-weight: 700;
				text-decoration: underline;
				text-decoration-thickness: 1.5px;
				text-underline-offset: 0.14em;
				transition: opacity 120ms ease;
			}
			.post-outro__link:hover {
				opacity: 0.8;
			}
			.post-outro__link:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: 2px;
				border-radius: 4px;
			}
			:global(.dark) .post-outro {
				background: rgba(255,255,255,0.04);
				border-color: rgba(255,255,255,0.12);
				border-top-color: rgba(var(--accent), 0.6);
				box-shadow: 0 6px 16px rgba(0, 0, 0, 0.14);
			}
			@media (max-width: 640px) {
				.post-outro {
					margin-top: 1.8rem;
					padding: 0.85rem 0.75rem 0.8rem;
					border-radius: var(--radius-md);
				}
				.post-outro__line {
					font-size: 0.95rem;
					line-height: 1.5;
				}
				.post-outro__title {
					font-size: 1.05rem;
				}
			}

		</style>
	</head>

	<body class="blog-post-page">
		<Header />
		
		<main id="top">
			
			<article>
				<div class="prose">
					<div class="title">
						<h1>
							<T>
								<span slot="en" lang="en">{title}</span>
								<span slot="ja" lang="ja" set:html={title_ja || title}></span>
								<span slot="en_simple" lang="en">{title_en_simple || title}</span>
							</T>
						</h1>
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
							{
								cameraUsedName && (
									<div class="post-meta-line">
										<div class="camera-used">
											{
												cameraUsedImage && (
													<img
														class="camera-used__thumb"
														src={cameraUsedImage}
														alt={cameraUsedImageAlt || `${cameraUsedName} image`}
														loading="lazy"
														decoding="async"
													/>
												)
											}
											<span class="camera-used__copy">
												<span class="camera-used__label">
													<T>
														<span slot="en" lang="en">Shot with:</span>
														<span slot="ja" lang="ja">撮影機材:</span>
														<span slot="en_simple" lang="en">Camera:</span>
													</T>
												</span>
												{
													cameraUsedLink ? (
														<a
															class="camera-used__link"
															href={cameraUsedLink}
															aria-label={cameraUsedLinkLabel || `Read post about ${cameraUsedName}`}
														>
															<span class="camera-used__name">{cameraUsedName}</span>
														</a>
													) : (
														<span class="camera-used__name">{cameraUsedName}</span>
													)
												}
											</span>
										</div>
									</div>
								)
							}
						</div>
					</div>
				</div>
						{heroImage && isOptimizedImageSrc(heroImage) &&
							<div class="hero-image">
							<OptimizedImage
							  src={heroImage}
					  sizes="(max-width: 960px) 100vw, 960px"
						  alt=""
						  loading="eager"
					  fetchpriority="high"

					  style={heroImageFit && `object-fit: ${heroImageFit}; background-color: ${heroImageFit === 'contain' ? 'black' : 'transparent'}`} />
					</div>
				}
				<div class="prose" data-blog-content>
					<slot />
					<div class="post-outro" aria-label="Post ending actions">
						<h3 class="post-outro__title">
							<T fluid>
								<span slot="en" lang="en">Thank you!</span>
								<span slot="ja" lang="ja">ありがとう！</span>
								<span slot="en_simple" lang="en">Thank you!</span>
							</T>
						</h3>
						<p class="post-outro__line">
							<T fluid>
								<span slot="en" lang="en">
									Thank you for reading. Please click on the doggy to leave a like, and go back to the top!
								</span>
								<span slot="ja" lang="ja">
									読んでくれてありがとうございます。わんこをクリックして「いいね」をして、ページの上へ戻ってね！
								</span>
								<span slot="en_simple" lang="en">
									Thank you for reading! Click the doggy to like this post, and go back to the top.
								</span>
							</T>
						</p>
						<p class="post-outro__line">
							<T fluid>
								<span slot="en" lang="en">
									Or click
									<a class="post-outro__link" href="/" aria-label="Return to posts page">here</a>
									to return to the posts page.
								</span>
								<span slot="ja" lang="ja">
									または
									<a class="post-outro__link" href="/" aria-label="記事一覧ページに戻る">ここ</a>
									をクリックして記事一覧ページに戻ってください。
								</span>
								<span slot="en_simple" lang="en">
									Or click
									<a class="post-outro__link" href="/" aria-label="Go back to posts page">here</a>
									to go back to the posts page.
								</span>
							</T>
						</p>
					</div>
				</div>
			</article>
			{slug && <LikeButton slug={slug} />}
		</main>
		<dialog class="lightbox-dialog" id="post-image-lightbox" aria-label="Expanded image">
			<div class="lightbox-content">
				<button class="lightbox-close" type="button" aria-label="Close image viewer">&times;</button>
				<img alt="" />
			</div>
		</dialog>
		<Footer />
			<script>
				document.addEventListener('astro:page-load', () => {
					const content = document.querySelector('.prose[data-blog-content]');
					const dialogEl = document.getElementById('post-image-lightbox');
					const dialog = dialogEl instanceof HTMLDialogElement ? dialogEl : null;
					const dialogImg = dialog?.querySelector('img');
					const dialogCloseBtn = dialog?.querySelector<HTMLButtonElement>('.lightbox-close');

					if (!content || !dialog || !dialogImg) return;

					const excludedSelector = [
						'a',
						'[data-no-lightbox]',
						'[data-lightbox="off"]',
						'.no-lightbox',
						'.scrapbook-container',
					].join(',');

					content.addEventListener('click', (event) => {
						const target = event.target;
						if (!(target instanceof HTMLImageElement)) return;
						if (target.closest(excludedSelector)) return;

						dialogImg.src = target.currentSrc || target.src;
						dialogImg.alt = target.alt || '';
						dialog.showModal();
					});

					dialog.addEventListener('click', (event) => {
						if (event.target === dialog) {
							dialog.close();
						}
					});

					dialogCloseBtn?.addEventListener('click', () => {
						dialog.close();
					});
				});
			</script>
	</body>
</html>
