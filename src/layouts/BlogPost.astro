---
import { Image, Picture } from 'astro:assets';

import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import LikeButton from '../components/LikeButton.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import T from '../components/T.astro';

const { title, title_ja, title_en_simple, description, pubDate, updatedDate, heroImage, slug, heroImageFit } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0 auto;
			}
			.hero-image {
				width: 100%;
				max-width: 1080px;
				margin: 0 auto 2rem auto;
			}
			.hero-image :global(img) {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				max-height: 510px;  
    			object-fit: cover;  
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 0.5em;
				padding: 0.5em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.25em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.prose :global(figure) {
				margin: 2em 0;
			}
			.prose :global(figure img) {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose :global(figcaption) {
				margin-top: 0.75em;
				font-size: 0.875em ;
				color: rgb(var(--gray)) ;
				text-align: center;
				font-style: italic;
				font-weight: 700 ;
				line-height: 1.5;
			}
		</style>
	</head>

	<body>
		<Header />
		
		<main>
			
			<article>
				<div class="prose">
					<div class="title">
						<h1>
							<T>
								<span slot="en">{title}</span>
								<span slot="ja">{title_ja || title}</span>
								<span slot="en_simple">{title_en_simple || title}</span>
							</T>
						</h1>
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
					</div>
				</div>
				{heroImage && 
					<div class="hero-image">
					<OptimizedImage
					  src={heroImage}
					  sizes="(max-width: 1020px) 100vw, 1020px"
					  alt=""
					  loading="eager"
					  style={heroImageFit && `object-fit: ${heroImageFit}; background-color: ${heroImageFit === 'contain' ? 'black' : 'transparent'}`} />
					</div>
				}
				<div class="prose">
					<slot />
				</div>
			</article>
			{slug && <LikeButton slug={slug} />}
		</main>
		<Footer />
	</body>
</html>
