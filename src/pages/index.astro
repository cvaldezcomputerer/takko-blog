---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import T from '../components/T.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child :global(img),
			ul li:first-child .placeholder-image { /* Style the placeholder */
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li :global(img),
			ul li .placeholder-image { /* Style the placeholder */
				margin-bottom: 0.5rem;
				border-radius: 12px;
				aspect-ratio: 720 / 360; /* Give it the same shape as the image */
				background-color: #f0f0f0; /* A light gray background */
				display: block;
				object-fit: cover;
				width: 100%; /* Ensure image fills container */
				height: auto;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover :global(img),
			ul a:hover .placeholder-image { /* Style the placeholder */
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul>
					{
						posts.map((post, index) => (
							<li>
								<a href={`/blog/${post.slug}/`}>
									{post.data.heroImage ? (
										<OptimizedImage
											src={post.data.heroImage}
											sizes={index === 0 ? "(max-width: 960px) 100vw, 960px" : "(max-width: 720px) 100vw, (max-width: 960px) 50vw, 480px"}
											alt={post.data.title}
											loading={index === 0 ? "eager" : "lazy"}
											fetchpriority={index === 0 ? "high" : "auto"}
											transition:name={`image-${post.slug}`}
										/>
									) : (
										<div class="placeholder-image" />
									)}
									<h4 class="title">
										<T fluid>
											<span slot="en">{post.data.title}</span>
											<span slot="ja">{post.data.title_ja || post.data.title}</span>
											<span slot="en_simple">{post.data.title_en_simple || post.data.title}</span>
										</T>
									</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>