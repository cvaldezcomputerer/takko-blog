---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import T from '../components/T.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			body {
				display: flex;
				flex-direction: column;
				min-height: 100vh;
				margin: 0;
			}
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
				flex: 1;
				display: flex;
				flex-direction: column;
			}
			.background-pattern {
				width: 100%;
				flex: 1;
				padding: 3rem 0;
				/* Pattern is handled by .pattern-bg class */
			}

			.content-wrapper {
				width: 1200px;
				max-width: calc(100% - 4rem);
				margin: 0 auto;
				position: relative;
				z-index: 1;
			}

			ul {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 3.5rem 4rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: 100%;
				opacity: 0;
				animation: fade-up 0.6s ease forwards;
			}

			ul li:first-child {
				grid-column: 1 / -1;
				margin-bottom: 0.5rem;
			}
			
			ul li:nth-child(1) { animation-delay: 0.1s; }
			ul li:nth-child(2) { animation-delay: 0.2s; }
			ul li:nth-child(3) { animation-delay: 0.3s; }
			ul li:nth-child(4) { animation-delay: 0.4s; }

			ul li:first-child a {
				display: grid;
				grid-template-columns: 1.1fr 0.9fr;
				gap: 5rem;
				align-items: center;
				text-align: left;
			}
			
			ul li :global(img),
			ul li .placeholder-image {
				margin: 0 auto 1.75rem auto;
				border-radius: 12px;
				aspect-ratio: 16 / 10;
				background-color: var(--secondary);
				display: block;
				object-fit: cover;
				width: 92%;
				transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), outline 0.3s ease;
			}

			ul li:first-child :global(img),
			ul li:first-child .placeholder-image {
				width: 100%;
				aspect-ratio: 16 / 9;
				margin: 0;
			}

			ul li a {
				display: block;
				text-decoration: none;
				overflow: hidden;
				border-radius: 12px;
			}

			ul li a:hover :global(img) {
				transform: scale(1.05);
				outline: 4px solid var(--accent);
				outline-offset: -4px;
			}

			.post-content {
				display: flex;
				flex-direction: column;
				width: 92%;
				margin: 0 auto;
			}

			ul li:first-child .post-content {
				width: 100%;
				margin: 0;
			}

			.title {
				margin: 0 0 0.75rem 0;
				color: rgb(var(--black));
				line-height: 1.3;
				font-weight: 700;
				letter-spacing: -0.01em;
				font-size: 1.6rem;
			}

			ul li:first-child .title {
				font-size: 3rem;
				line-height: 1.15;
				margin-bottom: 1.25rem;
			}

			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				font-weight: 500;
			}

			@keyframes fade-up {
				from {
					opacity: 0;
					transform: translateY(24px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@media (max-width: 1024px) {
				.content-wrapper {
					width: 100%;
				}
				.background-pattern {
					padding: 2rem 0;
				}
				ul {
					gap: 4rem 2rem;
				}
				ul li:first-child a {
					grid-template-columns: 1fr;
					gap: 2.5rem;
				}
				ul li:first-child .title {
					font-size: 2.25rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="background-pattern pattern-bg">
				<section class="content-wrapper">
					<ul>
						{
							posts.map((post, index) => (
								<li>
									<a href={`/blog/${post.slug}/`}>
										{post.data.heroImage ? (
											<OptimizedImage
												src={post.data.heroImage}
												sizes={index === 0 ? "(max-width: 960px) 100vw, 960px" : "(max-width: 720px) 100vw, (max-width: 960px) 50vw, 480px"}
												alt={post.data.title}
												loading={index === 0 ? "eager" : "lazy"}
												fetchpriority={index === 0 ? "high" : "auto"}
											/>
										) : (
											<div class="placeholder-image" />
										)}
										<div class="post-content">
											<h4 class="title">
												<T>
													<span slot="en">{post.data.title}</span>
													<span slot="ja">{post.data.title_ja || post.data.title}</span>
													<span slot="en_simple">{post.data.title_en_simple || post.data.title}</span>
												</T>
											</h4>
											<p class="date">
												<FormattedDate date={post.data.pubDate} />
											</p>
										</div>
									</a>
								</li>
							))
						}
					</ul>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>