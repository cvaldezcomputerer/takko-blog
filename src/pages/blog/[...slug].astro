---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import OptimizedImage from '../../components/media/OptimizedImage.astro';

export const prerender = true;

export async function getStaticPaths() {
	// Drafts are routable in dev so they can be previewed, but never in a
	// production build, so they never leak to the live site.
	const posts = await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft);
	return posts.map((post) => ({
		params: { slug: post.id.replace(/\.mdx?$/, '') },
		props: { post },
	}));
}

const { post } = Astro.props as { post: CollectionEntry<'blog'> };

const { Content } = await render(post);
---

<BlogPost {...post.data} slug={post.id.replace(/\.mdx?$/, '')}>
	<Content components={{ img: OptimizedImage }} />
</BlogPost>
