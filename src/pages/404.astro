---
import BaseHead from '../components/layout/BaseHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import T from '../components/i18n/T.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`404 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 5em 1em;
				text-align: center;
			}
			.logo-wrap {
				display: flex;
				justify-content: center;
				margin-bottom: 1rem;
			}
			.logo-404 {
				width: 140px;
				height: 140px;
				color: rgb(var(--gray));
			}
			:global(.dark) .logo-404 {
				color: rgb(var(--black));
			}
			h1 {
				font-size: 4em;
				margin: 0 0 0.4em;
				color: var(--accent);
				line-height: 1;
			}
			p {
				font-size: 1.1em;
				margin-bottom: 2em;
				color: rgb(var(--gray));
				line-height: 1.6;
			}
			p a {
				color: var(--accent);
				text-decoration: underline;
			}
			.home-btn {
				display: inline-block;
				padding: 0.75em 1.5em;
				background: var(--accent);
				color: white;
				text-decoration: none;
				border-radius: 8px;
				font-weight: bold;
				transition: transform 0.2s;
			}
			.home-btn:hover {
				transform: scale(1.05);
			}

			.error-section {
				margin-top: 3.5em;
				text-align: left;
			}
			.error-section-title {
				font-size: 0.8em;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: rgb(var(--gray));
				margin-bottom: 1em;
				text-align: center;
			}
			.error-cards {
				display: flex;
				gap: 0.75rem;
				justify-content: center;
				flex-wrap: wrap;
			}
			.error-card {
				flex: 1;
				min-width: 160px;
				max-width: 220px;
				background: var(--secondary);
				border: 1.5px solid transparent;
				border-radius: 10px;
				padding: 1em;
				text-align: left;
			}
			.error-card.is-current {
				border-color: var(--accent);
			}
			.error-code {
				font-size: 1.6em;
				font-weight: 700;
				line-height: 1;
				margin-bottom: 0.2em;
				color: rgb(var(--gray-dark));
			}
			.error-card.is-current .error-code {
				color: var(--accent);
			}
			.error-name {
				font-size: 0.78em;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: rgb(var(--gray));
				margin-bottom: 0.5em;
			}
			.error-desc {
				font-size: 0.85em;
				color: rgb(var(--gray));
				line-height: 1.5;
				margin: 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="logo-wrap">
				<!-- Logo with open-mouth state locked in (same SVG as like button hover state) -->
				<svg class="logo-404" viewBox="0 0 687 508" xmlns="http://www.w3.org/2000/svg">
					<g fill="currentColor">
						<g>
							<!-- Eyes squinted -->
							<path
								d="M449.18 347.92c-3.87 0-7-3.13-7-7v-65c0-3.86-3.13-7-7-7h-23.79c-3.87 0-7-3.13-7-7v-6c0-3.86 3.13-7 7-7h89.58c3.86 0 7 3.14 7 7v6c0 3.87-3.14 7-7 7h-23.79c-3.87 0-7 3.14-7 7v65c0 3.87-3.13 7-7 7z"
								style="transform: scaleY(0); opacity: 0; transform-box: fill-box; transform-origin: center;"
							/>
							<path
								d="M239.59 347.92c3.87 0 7-3.13 7-7v-65c0-3.86 3.14-7 7-7h23.79c3.87 0 7-3.13 7-7v-6c0-3.86-3.13-7-7-7h-89.57c-3.87 0-7 3.14-7 7v6c0 3.87 3.13 7 7 7h23.78c3.87 0 7 3.14 7 7v65c0 3.87 3.14 7 7 7z"
								style="transform: scaleY(0); opacity: 0; transform-box: fill-box; transform-origin: center;"
							/>
							<path fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" d="M411.39 300.92h89.58" />
							<path fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" d="M187.81 300.92h89.57" />
						</g>
						<!-- Smile hidden, open mouth shown -->
						<path
							d="M374.39 318.92c12.71 4.23 16.99 15.12 10.98 27.12-5.6 11.2-14.72 19.14-26.33 23.62-3.84.83-4.77 2.98-4.52 9.41-.32 5.91-.5 9.28 5.66 13 9.65 5.84 24.5 12.33 35.42 7.53 5.02-2.21 8.54-.95 10.21 2.75 1.71 3.75.33 8.26-4.42 10.37-9.59 4.25-30.04 2.38-30.04 2.38s-4.67 1.32-24.17-10.18c-19.5 11.5-24.17 10.18-24.17 10.18s-20.45 1.87-30.04-2.38c-4.75-2.11-6.13-6.62-4.42-10.37 1.67-3.7 5.19-4.96 10.21-2.75 10.92 4.8 25.77-1.69 35.42-7.53 6.15-3.72 5.97-7.09 5.66-13 .06-6.63-1.09-8.43-4.52-9.41-11.61-4.48-20.73-12.42-26.33-23.62-6.01-12-1.73-22.89 10.98-27.12 9.03-3.02 18.11-4.55 27.21-4.67 9.09.12 18.18 1.65 27.21 4.67"
							style="opacity: 0;"
						/>
						<ellipse cx="347.18" cy="400" rx="42" ry="55" stroke="currentColor" stroke-width="16" fill="none" />
						<path
							fill-rule="evenodd"
							clip-rule="evenodd"
							d="M90.85 402.39c-8.37-17.64-11.7-36.08-12.11-55.02-.11-4.72-1.84-5.23-5.54-5.02-13.34.73-26.24-1.05-38.39-6.96-31.26-15.18-42.7-45.29-29.25-77.34l42.96-65.97c21.63-27.7 46.47-51.4 80.54-63.24 10.72-3.73 21.56-6.87 33.16-6.32 6.87.33 13.15 1.94 18.59 6.24 1.66 1.32 3.13 2.14 5.35.9l65.6-28.05C271.62 93.95 281 80 290 59.5l7.48-16.81L362.5 0 361 15c1.5 30.5 15.18 50.77 37.8 72.81 52.68 25.76 80.3 38.97 97.3 41.74 1.79.92 3.53 1.8 5.58.34 15.06-10.79 30.94-8.36 47.24-3.31 26.08 8.09 48.1 22.23 66.94 41.94 25.46 26.65 48.55 55.12 64.25 88.59 13.01 27.72 5.77 54.49-19.36 72.19-13.68 9.64-28.96 13.77-45.68 13.07-7.69-.32-7.73.15-8.39 6.92-2.07 22.77-7.64 34.57-16.49 53.33-1.31 2.77-2.68 5.69-4.14 8.83-21.38 30.04-39.83 41.83-78.37 58.13-53.24 26.84-98.28 35.13-140.37 37.92-62.25.56-94.69-5.4-148.85-25.5-43.55-9.32-64.88-19.05-99.51-41.35-11.86-10.76-21.48-23.17-28.1-38.26m52.43-217.13c3.32-5.39 8.41-7.75 12.38-5.76 3.54 1.78 4.36 5.72 2.34 12l-12.78 57.42v.03c-2.35 13.75-4.7 27.51-9.39 40.77-6.33 17.9-14.46 34.47-32.66 43.45-2.56 1.26-3.45 3.35-3.46 6.1-.02 6.16.04 12.3.91 18.42 2.38 17.65 5.63 41.7 18.64 53.76 27.8 25.76 50.58 37.41 102.3 53.9 55.7 21.19 87.48 25.82 144.81 25.45 50.64-6.17 83.47-12.4 133.69-36.8 26.49-10.31 47.75-22 69.23-51.23 9.59-17.46 13.86-36.19 14.12-55.77.54-6.34-.64-8.94-4.36-12.56l-15.28-13.68c-14.38-18.97-21.1-40.95-25.6-63.82l-14.21-65.26c-.37-10.61.92-11.29 3.09-12.41l.12-.07c.13-.06.25-.13.38-.2 3.31-1.81 9.58 1.71 11.27 6.65 10.15 30.89 15.59 48.92 24.77 82.63 4.39 11.85 9.71 26.22 18.2 35.88 11.65 13.22 25.82 21.02 44.14 17.42 14.77-2.89 25.94-10.28 31.54-25.18 4.92-13.1 2.78-25.49-3.19-37.15-16.35-31.88-36.05-61.46-62.22-86.29-16.25-15.42-35.13-26.45-56.88-31.93-10.78-2.72-21.31-.58-27.65 9.59-3.83 6.15-10.96 1.88-10.96 1.88-36.74-17.94-68.25-28.17-104.57-50.89-11.17-10.53-22.44-17.11-29.94-32.11-7-12.5-9.65-20.42-12-43.5l-9.5 5c-7.27 3.53-8.25 9.06-9.51 16.14v.01c-2.58 14.44-2.99 33.35 8.51 49.35 1.07 1.5-2.83 1.02-5.7.67l-.19-.02c-7.33-.9-9.6-9.15-11.64-16.6l-4.33-31.83c-5.58 2.54-11.38 5.18-12.11 11.64-1.16 10.26-4.56 19.77-9.97 28.51-5.42 8.77-11.9 16.68-22.01 20.2-30.55 13.56-61.62 25.39-89.17 43.86-4.4 3.51-6.46 2.99-9.09-1.66-5.5-9.72-11.31-12.55-22.35-10.37-30.61 6.06-54.4 23.55-74.9 45.93-24.31 30.93-36.28 49.33-52.85 85.22-7.14 15.45 2.01 34.09 15.47 42.69 26.67 17.05 56.28 4.69 69.3-23.68 11.1-24.19 17.56-49.94 24.14-76.1 2.78-11.93 4.75-18.45 9.12-29.7"
						/>
					</g>
				</svg>
			</div>
			<h1>404</h1>
			<p>
				<T>
					<span slot="en">
						Sorry, that page doesn't exist! Please <a href="/contact">let me know</a> if something seems broken, or double-check that the address is correct.
					</span>
					<span slot="ja">
						そのページは見つかりませんでした！リンクが壊れているようであれば<a href="/contact">お知らせください</a>。アドレスが正しいかも確認してみてください。
					</span>
					<span slot="en_simple">
						Sorry, that page does not exist! Please <a href="/contact">tell me</a> if something is wrong, or check the address again.
					</span>
				</T>
			</p>
			<a href="/" class="home-btn">
				<T>
					<span slot="en">Go Back Home</span>
					<span slot="ja">ホームに戻る</span>
					<span slot="en_simple">Go Home</span>
				</T>
			</a>

			<div class="error-section">
				<p class="error-section-title">
					<T>
						<span slot="en">Common error codes</span>
						<span slot="ja">よくあるエラーコード</span>
						<span slot="en_simple">Common error codes</span>
					</T>
				</p>
				<div class="error-cards">
					<div class="error-card">
						<div class="error-code">403</div>
						<div class="error-name">Forbidden</div>
						<p class="error-desc">
							<T>
								<span slot="en">The page exists, but you don't have permission to see it.</span>
								<span slot="ja">ページは存在しますが、あなたには表示する権限がありません。</span>
								<span slot="en_simple">This page exists, but you cannot see it.</span>
							</T>
						</p>
					</div>
					<div class="error-card is-current">
						<div class="error-code">404</div>
						<div class="error-name">Not Found</div>
						<p class="error-desc">
							<T>
								<span slot="en">The page you're looking for doesn't exist — you're here now!</span>
								<span slot="ja">探しているページが存在しません。今まさにこのエラーです！</span>
								<span slot="en_simple">This page does not exist — you are here now!</span>
							</T>
						</p>
					</div>
					<div class="error-card">
						<div class="error-code">500</div>
						<div class="error-name">Server Error</div>
						<p class="error-desc">
							<T>
								<span slot="en">Something went wrong on the server's side. Not your fault!</span>
								<span slot="ja">サーバー側で問題が起きました。あなたのせいではありません！</span>
								<span slot="en_simple">The server has a problem. It is not your fault!</span>
							</T>
						</p>
					</div>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
