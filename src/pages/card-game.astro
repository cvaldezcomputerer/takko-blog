---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} — Card Game`} description="Simple card game with endless points cards" />
	</head>
	<body>
		<main class="card-game">
			<div class="card-game__header">
				<h1 class="card-game__title">Card Game</h1>
				<a href="/" class="card-game__back-link" data-astro-reload>← Back to Site</a>
			</div>

			<div class="card-game__container">
				<!-- Points Pile -->
				<div class="card-game__pile">
					<h2 class="card-game__pile-label">Points</h2>
					<button class="card-game__card" id="points-card" aria-label="Points card - click to reveal">
						<div class="card-game__card-content" id="points-content"></div>
					</button>
				</div>
			</div>

			<button class="card-game__reset" id="reset-btn">Reset Game</button>
		</main>

		<style is:global>
			body {
				margin: 0;
				padding: 0;
				min-height: 100vh;
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
				font-family: system-ui, -apple-system, sans-serif;
			}

			.card-game {
				min-height: 100vh;
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				padding: 2rem;
				box-sizing: border-box;
			}

			.card-game__header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 3rem;
				width: 100%;
				max-width: 1200px;
				gap: 2rem;
			}

			.card-game__title {
				margin: 0;
				font-size: 2.5rem;
				font-weight: 800;
				color: white;
				text-shadow: 0 2px 4px rgba(0,0,0,0.3);
			}

			.card-game__back-link {
				color: white;
				text-decoration: none;
				padding: 0.75rem 1.5rem;
				background: rgba(255,255,255,0.2);
				border-radius: 0.5rem;
				font-weight: 600;
				transition: background-color 0.2s ease;
				backdrop-filter: blur(10px);
			}

			.card-game__back-link:hover {
				background: rgba(255,255,255,0.3);
			}

			.card-game__container {
				display: flex;
				justify-content: center;
				width: 100%;
				max-width: 1200px;
				flex: 1;
			}

			.card-game__pile {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 2rem;
			}

			.card-game__pile-label {
				margin: 0;
				font-size: 1.5rem;
				font-weight: 700;
				color: white;
				text-shadow: 0 2px 4px rgba(0,0,0,0.3);
			}

			.card-game__card {
				position: relative;
				width: 100%;
				aspect-ratio: 3 / 4;
				max-width: 400px;
				min-height: 500px;
				border: 6px solid rgba(255,255,255,0.4);
				border-radius: 1.75rem;
				background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 40%, #f2994a 100%);
				cursor: pointer;
				transition: all 0.3s ease;
				outline: none;
				box-shadow: 0 12px 40px rgba(0,0,0,0.15);
				overflow: hidden;
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.card-game__card::before {
				content: "";
				position: absolute;
				inset: -2px;
				border-radius: 2rem;
				background: linear-gradient(135deg, rgba(255,255,255,0.6), rgba(255,255,255,0.1));
				opacity: 0.35;
				pointer-events: none;
			}

			.card-game__card:hover:not(.card-game__card--revealed):not(.card-game__card--revealing) {
				transform: translateY(-8px) scale(1.02);
				box-shadow: 0 18px 52px rgba(0,0,0,0.25);
				border-color: rgba(255,255,255,0.7);
			}

			/* Event card variant - uses random glow color */
			.card-game__card--event {
				background: radial-gradient(circle at top left, rgba(255,255,255,0.25), transparent 60%),
					linear-gradient(135deg, #5b21b6 0%, #7c3aed 40%, #ec4899 100%);
			}

			.card-game__card--event:hover:not(.card-game__card--revealing) {
				box-shadow:
					0 0 25px var(--event-glow, rgba(255,255,255,0.8)),
					0 0 60px var(--event-glow, rgba(255,255,255,0.6));
				border-color: var(--event-glow, rgba(255,255,255,0.9));
			}

			.card-game__card:focus-visible {
				box-shadow: 0 0 0 4px rgba(255,255,255,0.8);
			}

			.card-game__card--revealing {
				cursor: wait;
				animation: card-buildup 1s ease forwards;
			}

			@keyframes card-buildup {
				0% {
					transform: scale(1);
				}
				50% {
					transform: scale(1.1);
					box-shadow: 0 20px 60px rgba(255,255,255,0.4);
				}
				100% {
					transform: scale(1);
				}
			}

			.card-game__card--revealed {
				background: linear-gradient(135deg, #4ecdc4 0%, #44a08d 100%);
				cursor: default;
			}

			.card-game__card-content {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 100%;
				height: 100%;
				padding: 2rem;
				box-sizing: border-box;
				font-size: clamp(2rem, 5vw, 4rem);
				font-weight: 700;
				color: white;
				text-align: center;
				text-shadow:
					4px 4px 0px rgba(0,0,0,0.5),
					-2px -2px 0px rgba(0,0,0,0.3),
					2px 2px 0px rgba(0,0,0,0.3);
				word-wrap: break-word;
				overflow-wrap: break-word;
				opacity: 0;
				transition: opacity 0.3s ease;
			}

			.card-game__card--revealed .card-game__card-content {
				opacity: 1;
			}

			.card-game__reset {
				margin-top: 3rem;
				background: rgba(255,255,255,0.2);
				color: white;
				border: 2px solid rgba(255,255,255,0.3);
				padding: 1rem 2rem;
				border-radius: 0.5rem;
				cursor: pointer;
				font-weight: 700;
				font-size: 1.1rem;
				transition: all 0.2s ease;
				backdrop-filter: blur(10px);
			}

			.card-game__reset:hover {
				background: rgba(255,255,255,0.3);
				border-color: rgba(255,255,255,0.5);
				transform: translateY(-2px);
			}

			@media (max-width: 768px) {
				.card-game {
					padding: 1rem;
				}

				.card-game__header {
					flex-direction: column;
					align-items: flex-start;
					margin-bottom: 2rem;
				}

				.card-game__title {
					font-size: 2rem;
				}

				.card-game__card {
					max-width: 100%;
					min-height: 400px;
				}
			}
		</style>

		<script>
			import '/src/scripts/card-game.js';
		</script>
	</body>
</html>
